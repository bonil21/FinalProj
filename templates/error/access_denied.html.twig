{% extends 'base.html.twig' %}

{% block title %}Access Denied - GreenBites{% endblock %}

{% block body %}
<div style="max-width: 800px; margin: 4rem auto; padding: 2rem; text-align: center;">
    <div style="background: linear-gradient(135deg, #F6E6D7, #FAF0E8); border: 2px solid #E4CFBF; border-radius: 20px; padding: 3rem; box-shadow: 0 12px 32px rgba(0,0,0,0.1);">
        <div style="font-size: 4rem; margin-bottom: 1.5rem;">🚫</div>
        <h1 style="color: #2F5133; font-size: 2rem; font-weight: 900; margin-bottom: 1rem;">Access Denied</h1>
        <p style="color: #6b7280; font-size: 1.2rem; margin-bottom: 2rem;">
            Only admins can access this page.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            {% if is_granted('ROLE_STAFF') %}
                <a href="{{ path('staff_dashboard') }}" style="display: inline-block; background: #43b649; color: white; padding: 12px 32px; border-radius: 24px; text-decoration: none; font-weight: 700; font-size: 1.05rem; box-shadow: 0 4px 12px rgba(67, 182, 73, 0.3);">Go to Staff Dashboard</a>
            {% endif %}
            <a href="{{ path('app_landing_page') }}" style="display: inline-block; background: #6b7280; color: white; padding: 12px 32px; border-radius: 24px; text-decoration: none; font-weight: 700; font-size: 1.05rem;">Go to Homepage</a>
        </div>
    </div>
</div>
{% endblock %}

