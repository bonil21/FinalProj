{% extends 'base.html.twig' %}
{% block title %}Submit Feedback - GreenBites{% endblock %}

{% block body %}
<div class="feedback-form-container" style="max-width: 640px; margin: 2rem auto; padding: 2.5rem; background: #F6E6D7; border-radius: 20px; box-shadow: 0 8px 24px rgba(47,81,51,0.1); border: 1px solid #E4CFBF;">
  <div style="margin-bottom: 1.5rem;">
    <h1 style="color: #2F5133; margin: 0 0 0.5rem 0; font-size: 1.75rem; font-weight: 800;"><i class="bi bi-star"></i> Submit Feedback</h1>
    <p style="color: #374151; margin: 0; font-size: 0.95rem; line-height: 1.5;">We'd love to hear about your experience. Your feedback helps us improve.</p>
  </div>

  {% for message in app.flashes('success') %}
    <div style="background: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem;">
      {{ message }}
    </div>
  {% endfor %}

  {{ form_start(form, { attr: { style: 'display: flex; flex-direction: column; gap: 1.25rem;' } }) }}
    <div>
      {{ form_label(form.message) }}
      {{ form_widget(form.message, { attr: { style: 'width: 100%; padding: 0.75rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; font-size: 1rem; box-sizing: border-box;' } }) }}
      {{ form_errors(form.message) }}
    </div>
    <div>
      {{ form_label(form.rating) }}
      {{ form_widget(form.rating, { attr: { style: 'width: 100%; padding: 0.75rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; font-size: 1rem;' } }) }}
      {{ form_errors(form.rating) }}
    </div>
    <div>
      {{ form_label(form.product) }}
      {{ form_widget(form.product, { attr: { style: 'width: 100%; padding: 0.75rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; font-size: 1rem;' } }) }}
      {{ form_errors(form.product) }}
    </div>
    <div style="display: flex; gap: 1rem; align-items: center; margin-top: 0.5rem;">
      <button type="submit" style="background: #43b649; color: white; padding: 0.75rem 1.5rem; border: none; border-radius: 10px; font-weight: 600; cursor: pointer;">Submit Feedback</button>
      <a href="{{ path('feedback_index') }}" style="color: #6b7280; font-size: 0.95rem;">View my feedback history</a>
    </div>
  {{ form_end(form) }}
</div>
{% endblock %}
