{% extends 'base.html.twig' %}

{% block title %}Login - GreenBites{% endblock %}

{% block body %}
<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Login</h1>
    </div>
    <div class="auth-body">
      <a href="{{ path('app_landing_page') }}" class="back-link">← Back to Home</a>

      {% if password_changed is defined and password_changed %}
        <div class="alert alert-success">
          <strong>Password changed successfully!</strong> Please log in with your new password.
        </div>
      {% endif %}

      {% if password_reset is defined and password_reset %}
        <div class="alert alert-success" style="background: #e3f2fd; border: 1px solid #bbdefb; color: #0d47a1;">
          <strong>Password Reset Complete!</strong><br>
          Your password was reset successfully. Please sign in and change it immediately.
        </div>
      {% endif %}

      {% if error %}
        <div class="alert alert-danger">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      {% if app.user %}
        <div class="alert alert-danger">
          You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
        </div>
      {% endif %}

      <form method="post">
        <div class="form-group">
          <label for="username">Email</label>
          <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn-primary" type="submit">Sign In</button>
      </form>

      <div class="auth-footer">
        <p>Don't have an account? <a href="{{ path('app_register') }}">Register here</a></p>
      </div>
    </div>
  </div>
</div>
{% endblock %}
