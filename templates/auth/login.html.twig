{% extends 'base.html.twig' %}

{% block title %}Admin Login{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .login-wrapper { min-height: 100vh; display: grid; place-items: center; background: linear-gradient(135deg, #E7F0DC, #FFFFFF); padding: 2rem; }
    .login-card { width: 100%; max-width: 440px; background: #fff; border-radius: 16px; box-shadow: 0 12px 35px rgba(0,0,0,0.12); border: 1px solid #E4CFBF; overflow: hidden; }
    .login-header { padding: 1.5rem 2rem; background: #F6E6D7; border-bottom: 1px solid #E4CFBF; text-align: center; }
    .login-header h1 { margin: 0; color: #2F5133; font-weight: 900; }
    .login-body { padding: 2rem; }
    .form-group { margin-bottom: 1rem; }
    label { display:block; font-weight:700; color:#2F5133; margin-bottom:0.35rem; }
    .form-control { width: 100%; padding: 0.75rem 1rem; border: 2px solid #E4CFBF; border-radius: 10px; transition: all .2s; }
    .form-control:focus { outline: none; border-color: #6BB97F; box-shadow: 0 0 0 3px rgba(107, 185, 127, 0.2); }
    .btn-primary { width: 100%; background: #3B6B4A; color: #fff; border: none; padding: 0.75rem 1rem; border-radius: 10px; font-weight: 700; cursor: pointer; }
    .btn-primary:hover { background: #2F5133; }
    .alert { padding: 0.75rem 1rem; border-radius: 10px; background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; margin-bottom: 1rem; }
    .helper { text-align:center; margin-top:0.75rem; color:#6b7280; }
  </style>
{% endblock %}

{% block body %}
<div class="login-wrapper">
  <div class="login-card">
    <div class="login-header">
      <h1>🔐 Admin Login</h1>
    </div>
    <div class="login-body">
      {% if error %}
        <div class="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
      {% endif %}

      <form action="{{ path('app_login') }}" method="post">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="_username" class="form-control" value="{{ last_username }}" autocomplete="username" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="_password" class="form-control" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn-primary" type="submit">Sign in</button>
      </form>

      <div class="helper">Use username <strong>admin</strong> and password <strong>admin123</strong> (dev)</div>
    </div>
  </div>
</div>
{% endblock %}


