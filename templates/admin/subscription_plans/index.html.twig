{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}Subscription Plans - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear"></i> Subscription Plans</h2>
    <a href="{{ path('app_subscription_plan_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Plan
    </a>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Stats</h5>
                <div class="row text-center">
                    <div class="col-4">
                        <h4 class="text-primary">{{ totalPlans }}</h4>
                        <small class="text-muted">Total Plans</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-success">{{ activeCounts.active|default(0) }}</h4>
                        <small class="text-muted">Active</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-secondary">{{ activeCounts.inactive|default(0) }}</h4>
                        <small class="text-muted">Inactive</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a href="{{ path('app_subscription_index') }}" class="btn btn-outline-primary">
                        <i class="bi bi-list"></i> View Subscriptions
                    </a>
                    <a href="{{ path('app_payment_index') }}" class="btn btn-outline-success">
                        <i class="bi bi-credit-card"></i> View Payments
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Name, code, description">
            </div>
            <div class="col-md-3">
                <label class="form-label">Active State</label>
                <select name="active" class="form-select">
                    <option value="">All plans</option>
                    <option value="1" {% if activeFilter == '1' %}selected{% endif %}>Active</option>
                    <option value="0" {% if activeFilter == '0' %}selected{% endif %}>Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Per page</label>
                <select name="limit" class="form-select">
                    {% for opt in [6, 12, 24, 48] %}
                        <option value="{{ opt }}" {% if limit == opt %}selected{% endif %}>{{ opt }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
                <a href="{{ path('app_subscription_plan_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Plans</h5>
    </div>
    <div class="card-body">
        {% if plans is empty %}
            <div class="text-center py-5">
                <i class="bi bi-gear" style="font-size: 3rem;"></i>
                <h4 class="text-muted">No subscription plans found</h4>
                <p class="text-muted">Try changing the filter or create a new plan.</p>
                <a href="{{ path('app_subscription_plan_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Plan
                </a>
            </div>
        {% else %}
            <div class="row">
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 {% if not plan.active %}opacity-75{% endif %}">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">{{ plan.name }}</h6>
                                <span class="badge bg-{{ plan.active ? 'success' : 'secondary' }}">{{ plan.active ? 'Active' : 'Inactive' }}</span>
                            </div>
                            <div class="card-body">
                                <div class="mb-2"><code class="small">{{ plan.code }}</code></div>
                                <p class="card-text">{{ plan.description }}</p>
                                <div class="row text-center mb-2">
                                    <div class="col-6">
                                        <div class="fw-bold text-primary">${{ plan.price }}</div>
                                        <small class="text-muted">{{ plan.billingInterval }}</small>
                                    </div>
                                    <div class="col-6">
                                        <div class="fw-bold text-success">{{ plan.mealsIncluded }}</div>
                                        <small class="text-muted">meals</small>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer">
                                {% if plan.createdBy == app.user or plan.createdBy == null %}
                                    <div class="d-flex gap-2">
                                        <a href="{{ path('app_subscription_plan_edit', {'id': plan.id}) }}" class="btn btn-outline-primary btn-sm w-100">Edit</a>
                                        <form method="post" action="{{ path('app_subscription_plan_delete', {'id': plan.id}) }}" class="w-100" onsubmit="return confirm('Delete this plan?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">Delete</button>
                                        </form>
                                    </div>
                                {% else %}
                                    <small class="text-muted">Created by {{ plan.createdBy.email }}</small>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{% if totalPages > 1 %}
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Page {{ page }} of {{ totalPages }}</small>
        <div class="btn-group">
            <a class="btn btn-outline-secondary {% if page <= 1 %}disabled{% endif %}"
               href="{{ page <= 1 ? '#' : path('app_subscription_plan_index', {page: page - 1, limit: limit, active: activeFilter, q: search}) }}">
                Previous
            </a>
            <a class="btn btn-outline-secondary {% if page >= totalPages %}disabled{% endif %}"
               href="{{ page >= totalPages ? '#' : path('app_subscription_plan_index', {page: page + 1, limit: limit, active: activeFilter, q: search}) }}">
                Next
            </a>
        </div>
    </div>
{% endif %}
{% endblock %}
