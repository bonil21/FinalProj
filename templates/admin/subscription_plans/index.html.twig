{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}Subscription Plans - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear"></i> Subscription Plans</h2>
    <a href="{{ path('app_subscription_plan_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Plan
    </a>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Stats</h5>
                <div class="row text-center">
                    <div class="col-4">
                        <h4 class="text-primary">{{ plans|length }}</h4>
                        <small class="text-muted">Total Plans</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-success">{{ plans|filter(p => p.active)|length }}</h4>
                        <small class="text-muted">Active</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-secondary">{{ plans|filter(p => not p.active)|length }}</h4>
                        <small class="text-muted">Inactive</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a href="{{ path('app_subscription_index') }}" class="btn btn-outline-primary">
                        <i class="bi bi-list"></i> View Subscriptions
                    </a>
                    <a href="{{ path('app_payment_index') }}" class="btn btn-outline-success">
                        <i class="bi bi-credit-card"></i> View Payments
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">All Subscription Plans</h5>
    </div>
    <div class="card-body">
        {% if plans is empty %}
            <div class="text-center py-5">
                <i class="bi bi-gear" style="font-size: 3rem;"></i>
                <h4 class="text-muted">No subscription plans found</h4>
                <p class="text-muted">Create your first subscription plan to get started.</p>
                <a href="{{ path('app_subscription_plan_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Plan
                </a>
            </div>
        {% else %}
            <div class="row">
                {% for plan in plans %}
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 {% if not plan.active %}opacity-75{% endif %}">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h6 class="mb-0">{{ plan.name }}</h6>
                                <div>
                                    {% if plan.active %}
                                        <span class="badge bg-success">Active</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Inactive</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <code class="small">{{ plan.code }}</code>
                                </div>
                                <p class="card-text">{{ plan.description }}</p>
                                <div class="row text-center mb-3">
                                    <div class="col-6">
                                        <div class="fw-bold text-primary">${{ plan.price }}</div>
                                        <small class="text-muted">{{ plan.billingInterval }}</small>
                                    </div>
                                    <div class="col-6">
                                        <div class="fw-bold text-success">{{ plan.mealsIncluded }}</div>
                                        <small class="text-muted">meals</small>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer">
                                {% if plan.createdBy == app.user or plan.createdBy == null %}
                                    <div class="btn-group w-100" role="group">
                                        <a href="{{ path('app_subscription_plan_edit', {'id': plan.id}) }}" class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="deletePlan({{ plan.id }})">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </div>
                                {% else %}
                                    <div class="text-center">
                                        <small class="text-muted">Created by {{ plan.createdBy.email }}</small>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this subscription plan? This action cannot be undone and may affect existing subscriptions.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function deletePlan(id) {
    const form = document.getElementById('deleteForm');
    form.action = '/admin/subscriptions/plans/' + id;
    const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
    modal.show();
}
</script>
{% endblock %}
