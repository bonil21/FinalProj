{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}New Subscription Plan - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear"></i> New Subscription Plan</h2>
    <a href="{{ path('app_subscription_plan_index') }}" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Back to Plans
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Plan Details</h5>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            {{ form_label(form.code, 'Plan Code', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.code, {'attr': {'class': 'form-control', 'placeholder': 'e.g., BASIC_MONTHLY'}}) }}
                            {{ form_errors(form.code) }}
                            <div class="form-text">Unique identifier for this plan (uppercase, underscores)</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            {{ form_label(form.name, 'Plan Name', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Basic Monthly Plan'}}) }}
                            {{ form_errors(form.name) }}
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Describe what this plan includes...'}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="mb-3">
                            {{ form_label(form.price, 'Price', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.price) }}
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            {{ form_label(form.billingInterval, 'Billing Interval', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.billingInterval, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.billingInterval) }}
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            {{ form_label(form.mealsIncluded, 'Meals Included', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.mealsIncluded, {'attr': {'class': 'form-control', 'min': 1}}) }}
                            {{ form_errors(form.mealsIncluded) }}
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        {{ form_widget(form.active, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.active, 'Active Plan', {'label_attr': {'class': 'form-check-label'}}) }}
                        {{ form_errors(form.active) }}
                        <div class="form-text">Only active plans can be selected for new subscriptions</div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create Plan
                    </button>
                    <a href="{{ path('app_subscription_plan_index') }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Plan Preview</h5>
            </div>
            <div class="card-body">
                <div class="card bg-light">
                    <div class="card-header">
                        <h6 class="mb-0" id="preview-name">Plan Name</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <code class="small" id="preview-code">PLAN_CODE</code>
                        </div>
                        <p class="card-text small" id="preview-description">Plan description will appear here...</p>
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="fw-bold text-primary" id="preview-price">$0.00</div>
                                <small class="text-muted" id="preview-interval">monthly</small>
                            </div>
                            <div class="col-6">
                                <div class="fw-bold text-success" id="preview-meals">0</div>
                                <small class="text-muted">meals</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Tips</h5>
            </div>
            <div class="card-body">
                <h6>Plan Code</h6>
                <ul class="small">
                    <li>Use uppercase letters and underscores</li>
                    <li>Keep it short and descriptive</li>
                    <li>Examples: BASIC_MONTHLY, PREMIUM_YEARLY</li>
                </ul>
                
                <h6 class="mt-3">Pricing</h6>
                <ul class="small">
                    <li>Set competitive pricing</li>
                    <li>Consider different billing intervals</li>
                    <li>Include appropriate meal counts</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
// Live preview functionality
document.addEventListener('DOMContentLoaded', function() {
    const nameInput = document.querySelector('#subscription_plan_name');
    const codeInput = document.querySelector('#subscription_plan_code');
    const descriptionInput = document.querySelector('#subscription_plan_description');
    const priceInput = document.querySelector('#subscription_plan_price');
    const intervalSelect = document.querySelector('#subscription_plan_billingInterval');
    const mealsInput = document.querySelector('#subscription_plan_mealsIncluded');

    function updatePreview() {
        document.getElementById('preview-name').textContent = nameInput.value || 'Plan Name';
        document.getElementById('preview-code').textContent = codeInput.value || 'PLAN_CODE';
        document.getElementById('preview-description').textContent = descriptionInput.value || 'Plan description will appear here...';
        document.getElementById('preview-price').textContent = priceInput.value ? '$' + priceInput.value : '$0.00';
        document.getElementById('preview-interval').textContent = intervalSelect.options[intervalSelect.selectedIndex]?.text || 'monthly';
        document.getElementById('preview-meals').textContent = mealsInput.value || '0';
    }

    [nameInput, codeInput, descriptionInput, priceInput, intervalSelect, mealsInput].forEach(input => {
        if (input) {
            input.addEventListener('input', updatePreview);
            input.addEventListener('change', updatePreview);
        }
    });
});
</script>
{% endblock %}
