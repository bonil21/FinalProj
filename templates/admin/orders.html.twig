{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'orders' %}
{% block title %}Orders - Admin{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="https://cdn.datatables.net/1.10.21/css/dataTables.bootstrap5.min.css">
  <style>
    /* Professional card styling */
    .card {
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      border: none;
      border-radius: 12px;
    }
    .card-header {
      background: linear-gradient(135deg, #2F5133 0%, #3d5a40 100%);
      color: white;
      border-radius: 12px 12px 0 0 !important;
      border-bottom: none;
      padding: 1.5rem;
    }
    .card-body {
      padding: 2rem;
    }

    /* Ensure high-contrast table text regardless of page theme */
    .card .table thead th {
      color: #ffffff !important;
      background-color: #2F5133 !important;
      font-weight: 600;
      border: none;
      padding: 1rem 0.75rem;
    }
    .card .table tbody td {
      color: #1f2937 !important;
      border-color: #e5e7eb;
      padding: 0.875rem 0.75rem;
    }
    .card .table tbody tr:hover td {
      background: #FAF0E8;
    }
    .card .btn, .card .badge { color: inherit; }

    /* DataTables custom styling */
    .dataTables_wrapper .dataTables_length,
    .dataTables_wrapper .dataTables_filter,
    .dataTables_wrapper .dataTables_info,
    .dataTables_wrapper .dataTables_paginate {
      color: #2F5133;
      font-weight: 500;
    }
    .dataTables_wrapper .dataTables_filter input {
      border: 2px solid #E4CFBF;
      border-radius: 8px;
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
    }
    .dataTables_wrapper .dataTables_filter input:focus {
      border-color: #2F5133;
      box-shadow: 0 0 0 0.2rem rgba(47, 81, 51, 0.25);
    }

    /* Professional button styling */
    .btn {
      border-radius: 8px;
      font-weight: 500;
      padding: 0.5rem 1rem;
      transition: all 0.3s ease;
    }
    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
    }
    .btn-outline-info {
      border-color: #0dcaf0;
      color: #0dcaf0;
    }
    .btn-outline-info:hover {
      background-color: #0dcaf0;
      border-color: #0dcaf0;
    }
    .btn-outline-warning {
      border-color: #ffc107;
      color: #ffc107;
    }
    .btn-outline-warning:hover {
      background-color: #ffc107;
      border-color: #ffc107;
    }
    .btn-outline-danger {
      border-color: #dc3545;
      color: #dc3545;
    }
    .btn-outline-danger:hover {
      background-color: #dc3545;
      border-color: #dc3545;
    }

    /* Action buttons container */
    .action-buttons {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      align-items: center;
    }

    /* Badge styling */
    .badge {
      font-size: 0.75rem;
      padding: 0.375rem 0.75rem;
      border-radius: 20px;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
      .card-body {
        padding: 1rem;
      }
      .action-buttons {
        flex-direction: column;
        gap: 0.25rem;
      }
      .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
      }
    }

    /* DataTables buttons styling */
    .dt-buttons {
      margin-bottom: 1rem;
    }
    .dt-buttons .btn {
      margin-right: 0.5rem;
      border-radius: 6px;
    }


  </style>
{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title"><span class="emoji">📦</span> Orders</h1>
    <a href="{{ path('admin_orders_new') }}" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add New Order
    </a>
</div>

<div style="background: #F6E6D7; border: 1px solid #E4CFBF; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;">
  <form method="get" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; align-items: end;">
    <div>
      <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Search</label>
      <input type="text" name="search" placeholder="Order #, Customer..." value="{{ search }}" 
             style="width: 100%; padding: 0.5rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; box-sizing: border-box;">
    </div>
    <div>
      <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Status</label>
      <select name="status" style="width: 100%; padding: 0.5rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; box-sizing: border-box;">
        <option value="">All Statuses</option>
        {% for status in statuses %}
          <option value="{{ status }}" {% if statusFilter == status %}selected{% endif %}>{{ status|title }}</option>
        {% endfor %}
      </select>
    </div>
    <div>
      <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Date From</label>
      <input type="date" name="date_from" value="{{ dateFrom }}" 
             style="width: 100%; padding: 0.5rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; box-sizing: border-box;">
    </div>
    <div>
      <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Date To</label>
      <input type="date" name="date_to" value="{{ dateTo }}" 
             style="width: 100%; padding: 0.5rem 1rem; border: 1px solid #E4CFBF; border-radius: 8px; box-sizing: border-box;">
    </div>
    <div style="display: flex; gap: 0.5rem;">
      <button type="submit" style="background: #43b649; color: white; padding: 0.5rem 1rem; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; white-space: nowrap;">
        <i class="bi bi-search"></i> Filter
      </button>
      {% if search or statusFilter or dateFrom or dateTo %}
        <a href="{{ path('admin_orders') }}" style="background: #6b7280; color: white; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; font-weight: 600; white-space: nowrap;">
          <i class="bi bi-x-circle"></i> Clear
        </a>
      {% endif %}
    </div>
  </form>
</div>

<div class="card">
    <div class="card-body">
        {% if orders is empty %}
            <div class="text-center py-5">
                <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">No orders found</h4>
                <p class="text-muted">Start by adding your first order.</p>
                <a href="{{ path('admin_orders_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Add Order
                </a>
            </div>
        {% else %}
            <div class="table-responsive">
                <table id="ordersTable" class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-center">ID</th>
                            <th class="text-center">Order Number</th>
                            <th class="text-start">Customer</th>
                            <th class="text-end">Total Amount</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Created</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            <tr>
                                <td class="text-center">{{ order.id }}</td>
                                <td class="text-center">{{ order.orderNumber }}</td>
                                <td class="text-start">
                                    {% if order.customer %}
                                        {{ order.customer.name }}
                                    {% else %}
                                        <span class="text-muted">N/A</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">₱{{ order.totalAmount|number_format(2) }}</td>
                                <td class="text-center">
                                    {% set statusClass = {
                                        'pending': 'warning',
                                        'processing': 'info',
                                        'shipped': 'primary',
                                        'paid': 'success',
                                        'delivered': 'success',
                                        'cancelled': 'danger'
                                    } %}
                                    <span class="badge bg-{{ statusClass[order.status] ?? 'secondary' }}">{{ order.status|title }}</span>
                                </td>
                                <td class="text-center">{{ order.createdAt ? order.createdAt|date('M d, Y') : 'N/A' }}</td>
                                <td class="text-center">
                                    <div class="action-buttons">
                                        <a href="{{ path('admin_orders_show', {'id': order.id}) }}" class="btn btn-outline-info btn-sm" data-bs-toggle="tooltip" title="View order details">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <a href="{{ path('admin_orders_edit', {'id': order.id}) }}" class="btn btn-outline-warning btn-sm" data-bs-toggle="tooltip" title="Edit order information">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <form method="post" action="{{ path('admin_orders_delete', {'id': order.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" data-bs-toggle="tooltip" title="Delete order">
                                                <i class="fas fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}


    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.10.21/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.10.21/js/dataTables.bootstrap5.min.js"></script>
<script>
document.addEventListener('turbo:load', function() {
    $('#ordersTable').DataTable({
        "pageLength": 10,
        "lengthMenu": [5, 10, 25, 50, 100],
        "order": [[0, "desc"]],
        "dom": '<"d-flex justify-content-between align-items-center mb-3"<"dt-length"l><"dt-search"f>>rt<"d-flex justify-content-between align-items-center mt-3"<"dt-info"i><"dt-paginate"p>>',
        "language": {
            "search": "Search orders:",
            "lengthMenu": "Show _MENU_ orders per page",
            "info": "Showing _START_ to _END_ of _TOTAL_ orders",
            "infoEmpty": "No orders available",
            "infoFiltered": "(filtered from _MAX_ total orders)",
            "zeroRecords": "No matching orders found",
            "paginate": {
                "first": "First",
                "last": "Last",
                "next": "Next",
                "previous": "Previous"
            }
        },
        "initComplete": function() {
            // Initialize tooltips after DataTable is initialized
            $('[data-bs-toggle="tooltip"]').tooltip();
        }
    });

    // Initialize tooltips for static elements
    $('[data-bs-toggle="tooltip"]').tooltip();
});
</script>
{% endblock %}
