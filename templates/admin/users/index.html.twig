{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'users' %}
{% block title %}GreenBites | User Management{% endblock %}

{% block admin_content %}
  <div class="header mb-4">
    <h1 class="page-title"><i class="bi bi-people"></i> User Management</h1>
    <a href="{{ path('admin_users_new') }}" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Create User
    </a>
  </div>

  {% for message in app.flashes('success') %}
    <div class="staff-flash staff-flash--success">{{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('error') %}
    <div class="staff-flash staff-flash--error">{{ message }}</div>
  {% endfor %}

  <div class="card mb-4">
    <div class="card-body">
      <form method="get" class="d-flex gap-1">
        <input type="text" name="search" value="{{ search }}" placeholder="Search name/email" class="form-control">
        <select name="role" class="form-control">
          <option value="">All Roles</option>
          <option value="ROLE_ADMIN" {{ roleFilter == 'ROLE_ADMIN' ? 'selected' : '' }}>Admin</option>
          <option value="ROLE_STAFF" {{ roleFilter == 'ROLE_STAFF' ? 'selected' : '' }}>Staff</option>
          <option value="ROLE_USER" {{ roleFilter == 'ROLE_USER' ? 'selected' : '' }}>User</option>
        </select>
        <select name="status" class="form-control">
          <option value="">All Statuses</option>
          <option value="active" {{ statusFilter == 'active' ? 'selected' : '' }}>Active</option>
          <option value="disabled" {{ statusFilter == 'disabled' ? 'selected' : '' }}>Disabled</option>
        </select>
        <button type="submit" class="btn btn-primary">Filter</button>
        <a href="{{ path('admin_users_index') }}" class="btn btn-outline-info">Reset</a>
      </form>
    </div>
  </div>

  <div class="kpis mb-4">
    <div class="kpi">
      <div class="icon"><i class="bi bi-people"></i></div>
      <div class="meta"><span class="label">Total Users</span><span class="value">{{ totalUsers }}</span></div>
    </div>
    <div class="kpi">
      <div class="icon"><i class="bi bi-person-badge"></i></div>
      <div class="meta"><span class="label">Staff Accounts</span><span class="value">{{ totalStaff }}</span></div>
    </div>
    <div class="kpi">
      <div class="icon"><i class="bi bi-shield-lock"></i></div>
      <div class="meta"><span class="label">Admin Accounts</span><span class="value">{{ totalAdmins }}</span></div>
    </div>
  </div>

  <div class="table-section">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Roles</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for user in users %}
          <tr>
            <td>#{{ user.id }}</td>
            <td>{{ user.name ?? 'N/A' }}</td>
            <td>{{ user.email }}</td>
            <td>{{ user.roles|join(', ') }}</td>
            <td>{{ user.status|upper }}</td>
            <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : 'N/A' }}</td>
            <td>
              <a href="{{ path('admin_users_show', {id: user.id}) }}" class="btn btn-outline-info btn-sm">View</a>
              <a href="{{ path('admin_users_edit', {id: user.id}) }}" class="btn btn-outline-warning btn-sm">Edit</a>

              <form method="post" action="{{ path('admin_users_toggle_status', {id: user.id}) }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle_status' ~ user.id) }}">
                <button type="submit" class="btn btn-outline-warning btn-sm">
                  {{ user.status == 'active' ? 'Disable' : 'Enable' }}
                </button>
              </form>

              <form method="post" action="{{ path('admin_users_reset_password', {id: user.id}) }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('reset_password' ~ user.id) }}">
                <button type="submit" class="btn btn-outline-info btn-sm">Reset Pass</button>
              </form>

              <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" class="d-inline" onsubmit="return confirm('Delete this user?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="7" class="text-center">No users found.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
