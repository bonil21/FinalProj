{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'users' %}
{% block title %}GreenBites | Create User{% endblock %}

{% block admin_content %}
<div class="header">
  <h1 class="page-title"><i class="bi bi-person-plus"></i> Create New User</h1>
  <a href="{{ path('admin_users_index') }}" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Users</a>
</div>

<div style="max-width: 700px; margin: 0 auto;">
  <!-- Info Banner -->
  <div style="background: linear-gradient(135deg, #E7F0DC 0%, #F6E6D7 100%); padding: 1.25rem 1.5rem; border-radius: 12px; margin-bottom: 1.5rem; border-left: 4px solid #43b649; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <i class="bi bi-info-circle" style="font-size: 1.5rem; color: #43b649;"></i>
      <div>
        <h3 style="margin: 0 0 0.25rem 0; color: #2F5133; font-size: 1.1rem; font-weight: 700;">Create Admin or Staff Account</h3>
        <p style="margin: 0; color: #3b6b4a; font-size: 0.9rem;">Fill in the details below to create a new user account. Select the appropriate role (Admin or Staff) for the new user.</p>
      </div>
    </div>
  </div>

  <!-- Form Card -->
  <div style="background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border: 1px solid rgba(228, 207, 191, 0.3);">
    {{ form_start(form, {'attr': {'class': 'user-create-form', 'novalidate': 'novalidate'}}) }}
    
    <div style="display: grid; gap: 1.75rem;">
      <!-- Full Name Field -->
      <div class="form-field-wrapper">
        <label for="{{ form.name.vars.id }}" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: #2F5133; margin-bottom: 0.5rem; font-size: 0.95rem;">
          <i class="bi bi-person"></i> {{ form.name.vars.label }}
        </label>
        {{ form_widget(form.name, {'attr': {'class': 'form-input', 'placeholder': 'Enter full name'}}) }}
        {{ form_errors(form.name) }}
      </div>

      <!-- Email Field -->
      <div class="form-field-wrapper">
        <label for="{{ form.email.vars.id }}" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: #2F5133; margin-bottom: 0.5rem; font-size: 0.95rem;">
          <i class="bi bi-envelope"></i> {{ form.email.vars.label }}
        </label>
        {{ form_widget(form.email, {'attr': {'class': 'form-input', 'placeholder': 'user@example.com'}}) }}
        {{ form_errors(form.email) }}
      </div>

      <!-- Role Selection -->
      <div class="form-field-wrapper">
        <label for="{{ form.roles.vars.id }}" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: #2F5133; margin-bottom: 0.75rem; font-size: 0.95rem;">
          <i class="bi bi-shield-check"></i> {{ form.roles.vars.label }}
        </label>
        
        <!-- Role Cards -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem;">
          <div class="role-card" data-role="ROLE_USER" onclick="selectRole('ROLE_USER')">
            <i class="bi bi-person-circle" style="font-size: 2rem; color: #6b7280; margin-bottom: 0.5rem;"></i>
            <strong style="display: block; color: #2F5133; font-size: 0.95rem; margin-bottom: 0.25rem;">User</strong>
            <small style="color: #6b7280; font-size: 0.8rem;">Basic access</small>
          </div>
          <div class="role-card" data-role="ROLE_STAFF" onclick="selectRole('ROLE_STAFF')">
            <i class="bi bi-person-badge" style="font-size: 2rem; color: #43b649; margin-bottom: 0.5rem;"></i>
            <strong style="display: block; color: #2F5133; font-size: 0.95rem; margin-bottom: 0.25rem;">Staff</strong>
            <small style="color: #6b7280; font-size: 0.8rem;">Limited access</small>
          </div>
          <div class="role-card" data-role="ROLE_ADMIN" onclick="selectRole('ROLE_ADMIN')">
            <i class="bi bi-shield-check" style="font-size: 2rem; color: #d63031; margin-bottom: 0.5rem;"></i>
            <strong style="display: block; color: #2F5133; font-size: 0.95rem; margin-bottom: 0.25rem;">Admin</strong>
            <small style="color: #6b7280; font-size: 0.8rem;">Full access</small>
          </div>
        </div>
        
        <div style="margin-top: 1rem;">
          {{ form_widget(form.roles, {'attr': {'class': 'form-select'}}) }}
          {{ form_errors(form.roles) }}
          <small style="color: #6b7280; font-size: 0.85rem; display: block; margin-top: 0.5rem;">
            <i class="bi bi-info-circle"></i> You can select multiple roles if needed
          </small>
        </div>
      </div>

      <!-- Status Field -->
      <div class="form-field-wrapper">
        <label for="{{ form.status.vars.id }}" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: #2F5133; margin-bottom: 0.5rem; font-size: 0.95rem;">
          <i class="bi bi-toggle-on"></i> {{ form.status.vars.label }}
        </label>
        {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.status) }}
      </div>

      <!-- Password Field -->
      <div class="form-field-wrapper">
        <label for="{{ form.plainPassword.vars.id }}" style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; color: #2F5133; margin-bottom: 0.5rem; font-size: 0.95rem;">
          <i class="bi bi-lock"></i> Password
        </label>
        {{ form_widget(form.plainPassword, {'attr': {'class': 'form-input', 'placeholder': 'Enter password (min. 6 characters)'}}) }}
        {{ form_errors(form.plainPassword) }}
        <small style="color: #6b7280; font-size: 0.85rem; display: flex; align-items: center; gap: 0.25rem; margin-top: 0.5rem;">
          <i class="bi bi-shield-check"></i> Password must be at least 6 characters long
        </small>
      </div>
    </div>

    <!-- Action Buttons -->
    <div style="display: flex; gap: 1rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 2px solid #E4CFBF;">
      <button type="submit" class="btn btn-primary" style="flex: 1; padding: 0.875rem 1.75rem; font-size: 1rem; font-weight: 600; border-radius: 8px; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
        <i class="bi bi-check-circle"></i> Create User
      </button>
      <a href="{{ path('admin_users_index') }}" class="btn btn-secondary" style="padding: 0.875rem 1.75rem; font-size: 1rem; border-radius: 8px; display: flex; align-items: center; gap: 0.5rem; text-decoration: none;">
        <i class="bi bi-x-circle"></i> Cancel
      </a>
    </div>
    
    {{ form_end(form) }}
  </div>
</div>

<style>
  .user-create-form .form-field-wrapper {
    position: relative;
  }

  .user-create-form .form-input,
  .user-create-form .form-select {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 2px solid #E4CFBF;
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #fff;
    color: #2F5133;
    box-sizing: border-box;
  }

  .user-create-form .form-input:focus,
  .user-create-form .form-select:focus {
    outline: none;
    border-color: #43b649;
    box-shadow: 0 0 0 4px rgba(67, 182, 73, 0.1);
    background: #fff;
  }

  .user-create-form .form-input::placeholder {
    color: #9ca3af;
  }

  .role-card {
    padding: 1.25rem 1rem;
    border: 2px solid #E4CFBF;
    border-radius: 12px;
    background: #F6E6D7;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .role-card:hover {
    border-color: #6BB97F;
    background: #E7F0DC;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(67, 182, 73, 0.15);
  }

  .role-card.selected {
    border-color: #43b649;
    background: linear-gradient(135deg, #E7F0DC 0%, #D4E4C4 100%);
    box-shadow: 0 4px 16px rgba(67, 182, 73, 0.25);
    transform: translateY(-2px);
  }

  .role-card.selected i {
    color: #43b649 !important;
  }

  .user-create-form .form-errors {
    color: #d63031;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    display: block;
  }

  .user-create-form ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
  }

  .user-create-form ul li {
    color: #d63031;
    font-size: 0.875rem;
    padding: 0.25rem 0;
  }
</style>

<script>
  function selectRole(role) {
    const select = document.querySelector('select[name="{{ form.roles.vars.full_name }}"]');
    if (select) {
      // Handle multiple selection
      const options = Array.from(select.options);
      const selectedValues = Array.from(select.selectedOptions).map(opt => opt.value);
      
      if (selectedValues.includes(role)) {
        // Deselect if already selected
        options.forEach(opt => {
          if (opt.value === role) {
            opt.selected = false;
          }
        });
      } else {
        // Select the role
        options.forEach(opt => {
          if (opt.value === role) {
            opt.selected = true;
          }
        });
      }
      
      // Trigger change event
      select.dispatchEvent(new Event('change', { bubbles: true }));
      
      // Update card styles
      updateRoleCards();
    }
  }

  function updateRoleCards() {
    const select = document.querySelector('select[name="{{ form.roles.vars.full_name }}"]');
    if (select) {
      const selectedValues = Array.from(select.selectedOptions).map(opt => opt.value);
      document.querySelectorAll('.role-card').forEach(card => {
        const role = card.dataset.role;
        if (selectedValues.includes(role)) {
          card.classList.add('selected');
        } else {
          card.classList.remove('selected');
        }
      });
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function() {
    updateRoleCards();
    
    // Update cards when dropdown changes
    const select = document.querySelector('select[name="{{ form.roles.vars.full_name }}"]');
    if (select) {
      select.addEventListener('change', updateRoleCards);
    }
  });
</script>
{% endblock %}

