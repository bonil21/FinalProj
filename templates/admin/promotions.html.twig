{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'promotions' %}
{% block title %}Promotions - Admin{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    /* Table alignment classes */
    .text-center { text-align: center; }
    .text-start { text-align: left; }
    .text-end { text-align: right; }
    
    .promo-actions { margin-bottom: 1.5rem; }
    .promo-actions h3 { margin-bottom: 1rem; color: #2F5133; }
    .promo-actions button { background: #3B6B4A; color: white; padding: 0.5rem 1rem; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; }
    .promo-actions button:hover { background: #2F5133; }
    
    table { width: 100%; border-collapse: collapse; background: #F6E6D7; border-radius: 16px; overflow: hidden; box-shadow: 0 6px 20px rgba(0,0,0,0.05); }
    thead th { background: #ECD5C4; color: #2F5133; font-weight: 700; padding: 1rem; text-transform: uppercase; letter-spacing: 0.02em; font-size: 0.85rem; }
    tbody td { padding: 1rem; border-bottom: 1px solid #E4CFBF; }
    tbody tr:hover { background: #FAF0E8; }
    tbody tr:last-child td { border-bottom: none; }
    
    .btn-edit { background: #5CA36E; color: white; padding: 0.4rem 0.8rem; border: none; border-radius: 5px; margin-right: 0.5rem; cursor: pointer; }
    .btn-delete { background: #D9534F; color: white; padding: 0.4rem 0.8rem; border: none; border-radius: 5px; cursor: pointer; }
    .btn-edit:hover { background: #4A8B5A; }
    .btn-delete:hover { background: #C9302C; }
  </style>
{% endblock %}

{% block admin_content %}
<h1>🎉 Promotions</h1>
<p>Create and manage discounts, vouchers, and campaign offers here.</p>

<div class="promo-actions">
  <h3>Active Promotions</h3>
  <button>➕ Add New Promotion</button>
</div>

<table>
  <thead>
    <tr>
      <th class="text-start">Promo Name</th>
      <th class="text-center">Type</th>
      <th class="text-end">Discount</th>
      <th class="text-center">Start Date</th>
      <th class="text-center">End Date</th>
      <th class="text-center">Actions</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="text-start">Healthy Week Sale</td>
      <td class="text-center">Percentage</td>
      <td class="text-end">15%</td>
      <td class="text-center">Oct 10, 2025</td>
      <td class="text-center">Oct 20, 2025</td>
      <td class="text-center">
        <button class="btn-edit">Edit</button>
        <button class="btn-delete">Delete</button>
      </td>
    </tr>
    <tr>
      <td class="text-start">Juice Bundle Promo</td>
      <td class="text-center">Fixed Amount</td>
      <td class="text-end">₱50 Off</td>
      <td class="text-center">Nov 1, 2025</td>
      <td class="text-center">Nov 15, 2025</td>
      <td class="text-center">
        <button class="btn-edit">Edit</button>
        <button class="btn-delete">Delete</button>
      </td>
    </tr>
  </tbody>
</table>
{% endblock %}
