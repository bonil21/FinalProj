{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'payments' %}
{% block title %}Payment #{{ payment.id }} - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-credit-card"></i> Payment #{{ payment.id }}</h2>
    <a href="{{ path('app_payment_index') }}" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Back to Payments
    </a>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">{{ payment.customer.name }} ({{ payment.customer.email }})</dd>

            <dt class="col-sm-3">Amount</dt>
            <dd class="col-sm-9">${{ payment.amount }} {{ payment.currency|upper }}</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">{{ payment.status|title }}</dd>

            <dt class="col-sm-3">Method</dt>
            <dd class="col-sm-9">{{ payment.paymentMethod|title }}</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">{{ payment.description ?: '—' }}</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">{{ payment.createdAt ? payment.createdAt|date('M d, Y H:i') : '—' }}</dd>

            <dt class="col-sm-3">Paid At</dt>
            <dd class="col-sm-9">{{ payment.paidAt ? payment.paidAt|date('M d, Y H:i') : '—' }}</dd>

            <dt class="col-sm-3">Order</dt>
            <dd class="col-sm-9">{{ payment.order ? payment.order.orderNumber : '—' }}</dd>

            <dt class="col-sm-3">Subscription</dt>
            <dd class="col-sm-9">{{ payment.subscription ? payment.subscription.id : '—' }}</dd>

            <dt class="col-sm-3">Failure Reason</dt>
            <dd class="col-sm-9">{{ payment.failureReason ?: '—' }}</dd>
        </dl>
    </div>
</div>
{% endblock %}
