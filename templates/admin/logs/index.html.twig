{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'logs' %}
{% block title %}GreenBites | Activity Logs{% endblock %}

{% block admin_content %}
  <div class="header mb-4">
    <h1 class="page-title"><i class="bi bi-journal-text"></i> Activity Logs</h1>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <form method="get" class="d-flex gap-1">
        <input type="text" name="user" value="{{ userFilter }}" placeholder="User email" class="form-control">
        <input type="text" name="role" value="{{ roleFilter }}" placeholder="Role (e.g. ROLE_ADMIN)" class="form-control">
        <input type="text" name="action" value="{{ actionFilter }}" placeholder="Action (CREATE/UPDATE/...)" class="form-control">
        <input type="date" name="date_from" value="{{ dateFrom }}" class="form-control">
        <input type="date" name="date_to" value="{{ dateTo }}" class="form-control">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a href="{{ path('admin_logs_index') }}" class="btn btn-outline-info">Reset</a>
      </form>
    </div>
  </div>

  <div class="table-section">
    <table class="table">
      <thead>
        <tr>
          <th>When</th>
          <th>User</th>
          <th>Role</th>
          <th>Action</th>
          <th>Entity</th>
          <th>Details</th>
          <th>IP</th>
        </tr>
      </thead>
      <tbody>
        {% for log in logs %}
          <tr>
            <td>{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
            <td>{{ log.userEmail }}</td>
            <td>{{ log.userRole }}</td>
            <td>{{ log.action }}</td>
            <td>{{ log.entity ?? 'N/A' }}{% if log.entityId %} #{{ log.entityId }}{% endif %}</td>
            <td>
              {% if log.details %}
                <small>{{ log.details|json_encode(constant('JSON_UNESCAPED_UNICODE')) }}</small>
              {% else %}
                <span class="text-muted">N/A</span>
              {% endif %}
            </td>
            <td>{{ log.ipAddress ?? 'N/A' }}</td>
          </tr>
        {% else %}
          <tr>
            <td colspan="7" class="text-center">No logs found.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}
