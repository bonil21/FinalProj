{% extends 'base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('admin') }}
{% endblock %}

{% block body %}
<div class="dashboard-container">
  <div class="sidebar">
    <div>
      <img src="{{ asset('imageeee/logo.png') }}" alt="GreenBites Logo 2025" class="sidebar-logo-img">
      <h2>GreenBites</h2>
      <a href="{{ path('app_landing_page') }}" class="{% if active_menu is defined and active_menu == 'home' %}active{% endif %}"><i class="bi bi-house-door"></i> Home</a>
      <a href="{{ path('admin_dashboard') }}" class="{% if active_menu is defined and active_menu == 'dashboard' %}active{% endif %}"><i class="bi bi-speedometer2"></i> Dashboard Overview</a>
      <a href="{{ path('admin_products') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'products' %}active{% endif %}"><i class="bi bi-basket"></i> Products</a>
      <a href="{{ path('admin_orders') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'orders' %}active{% endif %}"><i class="bi bi-box-seam"></i> Orders</a>
      <a href="{{ path('app_subscription_index') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'subscriptions' %}active{% endif %}"><i class="bi bi-file-earmark-text"></i> Subscriptions</a>
      <a href="{{ path('admin_customers') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'customers' %}active{% endif %}"><i class="bi bi-people"></i> Customers</a>
      <a href="{{ path('app_payment_index') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'payments' %}active{% endif %}"><i class="bi bi-credit-card"></i> Payments & Transactions</a>
      <hr>
      <a href="{{ path('admin_feedback') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'feedback' %}active{% endif %}"><i class="bi bi-star"></i> Feedback / Reviews</a>
      <a href="{{ path('admin_settings') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'settings' %}active{% endif %}"><i class="bi bi-gear"></i> Settings</a>
      <hr>
      {% if is_granted('ROLE_ADMIN') %}
      <a href="{{ path('admin_users_index') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'users' %}active{% endif %}"><i class="bi bi-person"></i> User Management</a>
      <a href="{{ path('admin_logs_index') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'logs' %}active{% endif %}"><i class="bi bi-journal-text"></i> Activity Logs</a>
      <a href="{{ path('admin_profile') }}" class="sidebar-link-emphasis {% if active_menu is defined and active_menu == 'profile' %}active{% endif %}"><i class="bi bi-person-circle"></i> My Profile</a>
      {% endif %}
      <hr>
      <a href="{{ path('app_logout') }}" class="sidebar-logout-link"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </div>

  <div class="main-content">
    {% block admin_content %}{% endblock %}
  </div>
</div>
{% endblock %}


