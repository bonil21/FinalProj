{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}Subscriptions - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-file-earmark-text"></i> Subscriptions</h2>
    <a href="{{ path('app_subscription_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Subscription
    </a>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a href="{{ path('app_subscription_plan_index') }}" class="btn btn-outline-primary">
                        <i class="bi bi-gear"></i> Manage Plans
                    </a>
                    <a href="{{ path('app_payment_index') }}" class="btn btn-outline-success">
                        <i class="bi bi-credit-card"></i> View Payments
                    </a>
                    <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-info">
                        <i class="bi bi-arrow-left-right"></i> View Transactions
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Statistics</h5>
                <div class="row text-center">
                    <div class="col-4">
                        <h4 class="text-success">{{ statusCounts['active']|default(0) }}</h4>
                        <small class="text-muted">Active</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-warning">{{ statusCounts['trialing']|default(0) }}</h4>
                        <small class="text-muted">Trialing</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-danger">{{ statusCounts['cancelled']|default(0) }}</h4>
                        <small class="text-muted">Cancelled</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Customer, email, plan, subscription ID">
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All statuses</option>
                    {% for st in ['active', 'trialing', 'past_due', 'inactive', 'cancelled'] %}
                        <option value="{{ st }}" {% if statusFilter == st %}selected{% endif %}>{{ st|title }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Per page</label>
                <select name="limit" class="form-select">
                    {% for opt in [10, 20, 50, 100] %}
                        <option value="{{ opt }}" {% if limit == opt %}selected{% endif %}>{{ opt }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
                <a href="{{ path('app_subscription_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Subscriptions</h5>
        <small class="text-white-50">{{ totalSubscriptions }} result{{ totalSubscriptions == 1 ? '' : 's' }}</small>
    </div>
    <div class="card-body">
        {% if subscriptions is empty %}
            <div class="text-center py-5">
                <i class="bi bi-file-earmark-text" style="font-size: 3rem;"></i>
                <h4 class="text-muted">No subscriptions found</h4>
                <p class="text-muted">Try changing the filter or create a new subscription.</p>
                <a href="{{ path('app_subscription_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Subscription
                </a>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Plan</th>
                            <th>Status</th>
                            <th>Start Date</th>
                            <th>Current Period</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for subscription in subscriptions %}
                            <tr>
                                <td>{{ subscription.id }}</td>
                                <td>
                                    {% if subscription.customer %}
                                        <div class="fw-semibold">{{ subscription.customer.name }}</div>
                                        <small class="text-muted">{{ subscription.customer.email }}</small>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if subscription.plan %}
                                        <div class="fw-semibold">{{ subscription.plan.name }}</div>
                                        <small class="text-muted">{{ subscription.plan.mealsIncluded }} meals</small>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% set statusClass = {
                                        'active': 'success',
                                        'inactive': 'secondary',
                                        'cancelled': 'danger',
                                        'past_due': 'warning',
                                        'trialing': 'info'
                                    } %}
                                    <span class="badge bg-{{ statusClass[subscription.status] ?? 'secondary' }}">
                                        {{ subscription.status|title }}
                                    </span>
                                </td>
                                <td>{{ subscription.startDate ? subscription.startDate|date('M d, Y') : '-' }}</td>
                                <td>
                                    {% if subscription.currentPeriodStart and subscription.currentPeriodEnd %}
                                        <small>{{ subscription.currentPeriodStart|date('M d') }} - {{ subscription.currentPeriodEnd|date('M d, Y') }}</small>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td class="text-nowrap">
                                    <a href="{{ path('app_subscription_show', {'id': subscription.id}) }}" class="btn btn-outline-info btn-sm">View</a>
                                    {% if subscription.createdBy == app.user or subscription.createdBy == null %}
                                        <a href="{{ path('app_subscription_edit', {'id': subscription.id}) }}" class="btn btn-outline-warning btn-sm">Edit</a>
                                        <form method="post" action="{{ path('app_subscription_delete', {'id': subscription.id}) }}" class="d-inline" onsubmit="return confirm('Delete this subscription?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subscription.id) }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

{% if totalPages > 1 %}
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Page {{ page }} of {{ totalPages }}</small>
        <div class="btn-group">
            <a class="btn btn-outline-secondary {% if page <= 1 %}disabled{% endif %}"
               href="{{ page <= 1 ? '#' : path('app_subscription_index', {page: page - 1, limit: limit, status: statusFilter, q: search}) }}">
                Previous
            </a>
            <a class="btn btn-outline-secondary {% if page >= totalPages %}disabled{% endif %}"
               href="{{ page >= totalPages ? '#' : path('app_subscription_index', {page: page + 1, limit: limit, status: statusFilter, q: search}) }}">
                Next
            </a>
        </div>
    </div>
{% endif %}
{% endblock %}
