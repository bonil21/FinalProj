{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}Subscription Details - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-file-earmark-text"></i> Subscription Details</h2>
    <div>
        {% if subscription.createdBy == app.user or subscription.createdBy == null %}
            <a href="{{ path('app_subscription_edit', {'id': subscription.id}) }}" class="btn btn-outline-primary me-2">
                <i class="fas fa-edit"></i> Edit
            </a>
        {% endif %}
        <a href="{{ path('app_subscription_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to Subscriptions
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Subscription Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Customer Information</h6>
                        <div class="d-flex align-items-center mb-3">
                            <div class="avatar-lg bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                                {{ subscription.customer.name|first|upper }}
                            </div>
                            <div>
                                <div class="fw-bold">{{ subscription.customer.name }}</div>
                                <div class="text-muted">{{ subscription.customer.email }}</div>
                                <div class="text-muted">{{ subscription.customer.phone }}</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Plan Information</h6>
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title">{{ subscription.plan.name }}</h5>
                                <p class="card-text">{{ subscription.plan.description }}</p>
                                <div class="d-flex justify-content-between">
                                    <span class="badge bg-primary">{{ subscription.plan.mealsIncluded }} meals</span>
                                    <span class="fw-bold">${{ subscription.plan.price }}/{{ subscription.plan.billingInterval }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr>

                <div class="row">
                    <div class="col-md-6">
                        <h6>Subscription Status</h6>
                        {% set statusClass = {
                            'active': 'success',
                            'inactive': 'secondary',
                            'cancelled': 'danger',
                            'past_due': 'warning',
                            'trialing': 'info'
                        } %}
                        <span class="badge bg-{{ statusClass[subscription.status] ?? 'secondary' }} fs-6">
                            {{ subscription.status|title }}
                        </span>
                        
                        {% if subscription.cancelAtPeriodEnd %}
                            <span class="badge bg-warning ms-2">Will Cancel at Period End</span>
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        <h6>Stripe Integration</h6>
                        {% if subscription.stripeSubscriptionId %}
                            <code class="small">{{ subscription.stripeSubscriptionId }}</code>
                        {% else %}
                            <span class="text-muted">Not connected to Stripe</span>
                        {% endif %}
                    </div>
                </div>

                <hr>

                <div class="row">
                    <div class="col-md-4">
                        <h6>Start Date</h6>
                        {% if subscription.startDate %}
                            <p class="mb-0">{{ subscription.startDate|date('F d, Y') }}</p>
                        {% else %}
                            <p class="text-muted mb-0">Not set</p>
                        {% endif %}
                    </div>
                    <div class="col-md-4">
                        <h6>Current Period Start</h6>
                        {% if subscription.currentPeriodStart %}
                            <p class="mb-0">{{ subscription.currentPeriodStart|date('F d, Y') }}</p>
                        {% else %}
                            <p class="text-muted mb-0">Not set</p>
                        {% endif %}
                    </div>
                    <div class="col-md-4">
                        <h6>Current Period End</h6>
                        {% if subscription.currentPeriodEnd %}
                            <p class="mb-0">{{ subscription.currentPeriodEnd|date('F d, Y') }}</p>
                        {% else %}
                            <p class="text-muted mb-0">Not set</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-success" onclick="activateSubscription()">
                        <i class="fas fa-play"></i> Activate
                    </button>
                    <button class="btn btn-warning" onclick="pauseSubscription()">
                        <i class="fas fa-pause"></i> Pause
                    </button>
                    <button class="btn btn-danger" onclick="cancelSubscription()">
                        <i class="fas fa-stop"></i> Cancel
                    </button>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Subscription History</h5>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker bg-primary"></div>
                        <div class="timeline-content">
                            <h6 class="timeline-title">Subscription Created</h6>
                            <p class="timeline-text">{{ subscription.createdAt|date('M d, Y H:i') }}</p>
                        </div>
                    </div>
                    {% if subscription.startDate %}
                    <div class="timeline-item">
                        <div class="timeline-marker bg-success"></div>
                        <div class="timeline-content">
                            <h6 class="timeline-title">Subscription Started</h6>
                            <p class="timeline-text">{{ subscription.startDate|date('M d, Y') }}</p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function activateSubscription() {
    if (confirm('Are you sure you want to activate this subscription?')) {
        // Add activation logic here
        alert('Subscription activation feature coming soon!');
    }
}

function pauseSubscription() {
    if (confirm('Are you sure you want to pause this subscription?')) {
        // Add pause logic here
        alert('Subscription pause feature coming soon!');
    }
}

function cancelSubscription() {
    if (confirm('Are you sure you want to cancel this subscription?')) {
        // Add cancellation logic here
        alert('Subscription cancellation feature coming soon!');
    }
}
</script>

<style>
.avatar-lg {
    width: 60px;
    height: 60px;
    font-size: 24px;
}

.timeline {
    position: relative;
    padding-left: 30px;
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-marker {
    position: absolute;
    left: -35px;
    top: 5px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
}

.timeline-content {
    padding-left: 15px;
}

.timeline-title {
    margin-bottom: 5px;
    font-size: 14px;
}

.timeline-text {
    margin-bottom: 0;
    font-size: 12px;
    color: #6c757d;
}
</style>
{% endblock %}
