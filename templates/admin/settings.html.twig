{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'settings' %}
{% block title %}Settings - Admin{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    /* Settings Page Specific Styles */
    .settings-header {
      background: linear-gradient(135deg, #E7F0DC, #FFFFFF);
      color: #2F5133;
      border-radius: 20px;
      box-shadow: 0 12px 35px rgba(0,0,0,0.12);
      border: 3px solid #6BB97F;
      padding: 2rem;
      margin-bottom: 2rem;
      text-align: center;
    }
    
    .settings-header h1 {
      font-size: 2.5rem;
      font-weight: 900;
      margin: 0 0 0.5rem 0;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.15);
    }
    
    .settings-header p {
      font-size: 1.1rem;
      margin: 0;
      color: #3B6B4A;
      font-weight: 600;
    }

    .settings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .settings-card {
      background: linear-gradient(135deg, #FFFFFF, #F6E6D7);
      border: 1px solid #E4CFBF;
      border-radius: 20px;
      box-shadow: 0 12px 35px rgba(0,0,0,0.1);
      padding: 0;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .settings-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    .settings-card-header {
      background: linear-gradient(135deg, #ECD5C4, #E4CFBF);
      border-radius: 20px 20px 0 0;
      padding: 1.5rem 2rem;
      border-bottom: 1px solid #E4CFBF;
    }

    .settings-card-header h3 {
      margin: 0;
      color: #2F5133;
      font-weight: 900;
      font-size: 1.3rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .settings-card-body {
      padding: 2rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group:last-child {
      margin-bottom: 0;
    }

    .form-label {
      display: block;
      font-weight: 700;
      color: #2F5133;
      margin-bottom: 0.5rem;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    .form-control {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 2px solid #E4CFBF;
      border-radius: 12px;
      font-size: 1rem;
      transition: all 0.3s ease;
      background: #FFFFFF;
      color: #2F5133;
    }

    .form-control:focus {
      outline: none;
      border-color: #6BB97F;
      box-shadow: 0 0 0 3px rgba(107, 185, 127, 0.2);
      background: #FAF0E8;
    }

    .form-control::placeholder {
      color: #9ca3af;
      font-style: italic;
    }

    .btn-save {
      background: linear-gradient(135deg, #3B6B4A, #2F5133);
      color: #FFFFFF;
      border: none;
      padding: 0.75rem 2rem;
      border-radius: 12px;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .btn-save:hover {
      background: linear-gradient(135deg, #2F5133, #1a3d26);
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(47, 81, 51, 0.3);
    }

    .btn-save:active {
      transform: translateY(0);
    }

    .password-strength {
      margin-top: 0.5rem;
      font-size: 0.85rem;
    }

    .strength-bar {
      height: 4px;
      background: #E4CFBF;
      border-radius: 2px;
      margin-top: 0.25rem;
      overflow: hidden;
    }

    .strength-fill {
      height: 100%;
      transition: width 0.3s ease, background-color 0.3s ease;
      width: 0%;
    }

    .strength-weak { background-color: #dc3545; }
    .strength-medium { background-color: #ffc107; }
    .strength-strong { background-color: #28a745; }

    .form-help {
      font-size: 0.85rem;
      color: #6b7280;
      margin-top: 0.25rem;
      font-style: italic;
    }

    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 60px;
      height: 34px;
    }

    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .toggle-slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #E4CFBF;
      transition: 0.4s;
      border-radius: 34px;
    }

    .toggle-slider:before {
      position: absolute;
      content: "";
      height: 26px;
      width: 26px;
      left: 4px;
      bottom: 4px;
      background-color: white;
      transition: 0.4s;
      border-radius: 50%;
    }

    input:checked + .toggle-slider {
      background-color: #6BB97F;
    }

    input:checked + .toggle-slider:before {
      transform: translateX(26px);
    }

    .toggle-group {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem;
      background: #FAF0E8;
      border-radius: 12px;
      margin-bottom: 1rem;
    }

    .toggle-label {
      font-weight: 600;
      color: #2F5133;
    }

    .toggle-description {
      font-size: 0.85rem;
      color: #6b7280;
      margin-top: 0.25rem;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .settings-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      
      .settings-header h1 {
        font-size: 2rem;
      }
      
      .settings-card-body {
        padding: 1.5rem;
      }
    }

    /* Success/Error States */
    .alert {
      padding: 1rem 1.5rem;
      border-radius: 12px;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    .alert-success {
      background: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
    }

    .alert-error {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }

    /* Loading State */
    .btn-save.loading {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .btn-save.loading::after {
      content: "";
      width: 16px;
      height: 16px;
      border: 2px solid transparent;
      border-top: 2px solid #FFFFFF;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>
{% endblock %}

{% block admin_content %}
<div class="settings-header">
  <h1 class="page-title"><span class="emoji">⚙️</span> Settings</h1>
  <p>Adjust system configurations, admin credentials, and preferences here.</p>
  
</div>

<div class="settings-grid">
  <!-- Admin Profile Settings -->
  <div class="settings-card">
    <div class="settings-card-header">
      <h3>
        <i class="fas fa-user"></i>
        Admin Profile
      </h3>
    </div>
    <div class="settings-card-body">
      <form id="profileForm">
        <div class="form-group">
          <label for="adminName" class="form-label">Full Name</label>
          <input type="text" id="adminName" class="form-control" value="Nathaniel Gilbero" placeholder="Enter your full name">
          <div class="form-help">This will be displayed in the admin dashboard</div>
        </div>
        
        <div class="form-group">
          <label for="adminEmail" class="form-label">Email Address</label>
          <input type="email" id="adminEmail" class="form-control" value="admin@greenbites.com" placeholder="Enter your email address">
          <div class="form-help">Used for system notifications and login</div>
        </div>
        
        <button type="submit" class="btn-save">
          <i class="fas fa-save"></i>
          Save Changes
        </button>
      </form>
    </div>
  </div>

  <!-- Password Settings -->
  <div class="settings-card">
    <div class="settings-card-header">
      <h3>
        <i class="fas fa-lock"></i>
        Change Password
      </h3>
    </div>
    <div class="settings-card-body">
      <form id="passwordForm">
        <div class="form-group">
          <label for="oldPass" class="form-label">Current Password</label>
          <input type="password" id="oldPass" class="form-control" placeholder="Enter current password">
        </div>
        
        <div class="form-group">
          <label for="newPass" class="form-label">New Password</label>
          <input type="password" id="newPass" class="form-control" placeholder="Enter new password">
          <div class="password-strength">
            <div class="strength-bar">
              <div class="strength-fill" id="strengthFill"></div>
            </div>
            <span id="strengthText">Password strength</span>
          </div>
        </div>
        
        <div class="form-group">
          <label for="confirmPass" class="form-label">Confirm New Password</label>
          <input type="password" id="confirmPass" class="form-control" placeholder="Confirm new password">
          <div class="form-help">Must match the new password above</div>
        </div>
        
        <button type="submit" class="btn-save">
          <i class="fas fa-key"></i>
          Update Password
        </button>
      </form>
    </div>
  </div>

  <!-- System Preferences -->
  <div class="settings-card">
    <div class="settings-card-header">
      <h3>
        <i class="fas fa-cog"></i>
        System Preferences
      </h3>
    </div>
    <div class="settings-card-body">
      <form id="preferencesForm">
        <div class="form-group">
          <label for="theme" class="form-label">Theme Preference</label>
          <select id="theme" class="form-control">
            <option value="light">🌞 Light Mode</option>
            <option value="dark">🌙 Dark Mode</option>
            <option value="auto">🔄 Auto (System)</option>
          </select>
          <div class="form-help">Choose your preferred color scheme</div>
        </div>

        <div class="toggle-group">
          <div>
            <div class="toggle-label">Email Notifications</div>
            <div class="toggle-description">Receive email alerts for important events</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="notifications" checked>
            <span class="toggle-slider"></span>
          </label>
        </div>

        <div class="toggle-group">
          <div>
            <div class="toggle-label">Auto-save Changes</div>
            <div class="toggle-description">Automatically save form changes</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="autosave" checked>
            <span class="toggle-slider"></span>
          </label>
        </div>

        <div class="toggle-group">
          <div>
            <div class="toggle-label">Two-Factor Authentication</div>
            <div class="toggle-description">Add extra security to your account</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="twoFactor">
            <span class="toggle-slider"></span>
          </label>
        </div>
        
        <button type="submit" class="btn-save">
          <i class="fas fa-check"></i>
          Apply Preferences
        </button>
      </form>
    </div>
  </div>

  <!-- Security Settings -->
  <div class="settings-card">
    <div class="settings-card-header">
      <h3>
        <i class="fas fa-shield-alt"></i>
        Security Settings
      </h3>
    </div>
    <div class="settings-card-body">
      <form id="securityForm">
        <div class="form-group">
          <label for="sessionTimeout" class="form-label">Session Timeout</label>
          <select id="sessionTimeout" class="form-control">
            <option value="15">15 minutes</option>
            <option value="30" selected>30 minutes</option>
            <option value="60">1 hour</option>
            <option value="120">2 hours</option>
          </select>
          <div class="form-help">How long to stay logged in when inactive</div>
        </div>

        <div class="toggle-group">
          <div>
            <div class="toggle-label">Login Notifications</div>
            <div class="toggle-description">Get notified of new login attempts</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="loginNotifications" checked>
            <span class="toggle-slider"></span>
          </label>
        </div>

        <div class="toggle-group">
          <div>
            <div class="toggle-label">IP Restrictions</div>
            <div class="toggle-description">Limit access to specific IP addresses</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="ipRestrictions">
            <span class="toggle-slider"></span>
          </label>
        </div>
        
        <button type="submit" class="btn-save">
          <i class="fas fa-shield-alt"></i>
          Update Security
        </button>
      </form>
    </div>
  </div>
</div>

<script>
// Password strength indicator
document.getElementById('newPass').addEventListener('input', function() {
  const password = this.value;
  const strengthFill = document.getElementById('strengthFill');
  const strengthText = document.getElementById('strengthText');
  
  let strength = 0;
  let strengthClass = '';
  let strengthLabel = '';
  
  if (password.length >= 8) strength += 25;
  if (/[a-z]/.test(password)) strength += 25;
  if (/[A-Z]/.test(password)) strength += 25;
  if (/[0-9]/.test(password)) strength += 25;
  
  if (strength < 50) {
    strengthClass = 'strength-weak';
    strengthLabel = 'Weak';
  } else if (strength < 75) {
    strengthClass = 'strength-medium';
    strengthLabel = 'Medium';
  } else {
    strengthClass = 'strength-strong';
    strengthLabel = 'Strong';
  }
  
  strengthFill.style.width = strength + '%';
  strengthFill.className = 'strength-fill ' + strengthClass;
  strengthText.textContent = strengthLabel + ' password';
});

// Form submission handlers
document.getElementById('profileForm').addEventListener('submit', function(e) {
  e.preventDefault();
  const btn = this.querySelector('.btn-save');
  btn.classList.add('loading');
  
  setTimeout(() => {
    btn.classList.remove('loading');
    // Show success message
    showAlert('Profile updated successfully!', 'success');
  }, 1500);
});

document.getElementById('passwordForm').addEventListener('submit', function(e) {
  e.preventDefault();
  const btn = this.querySelector('.btn-save');
  btn.classList.add('loading');
  
  setTimeout(() => {
    btn.classList.remove('loading');
    // Show success message
    showAlert('Password updated successfully!', 'success');
    this.reset();
  }, 1500);
});

document.getElementById('preferencesForm').addEventListener('submit', function(e) {
  e.preventDefault();
  const btn = this.querySelector('.btn-save');
  btn.classList.add('loading');
  
  setTimeout(() => {
    btn.classList.remove('loading');
    // Show success message
    showAlert('Preferences saved successfully!', 'success');
  }, 1500);
});

document.getElementById('securityForm').addEventListener('submit', function(e) {
  e.preventDefault();
  const btn = this.querySelector('.btn-save');
  btn.classList.add('loading');
  
  setTimeout(() => {
    btn.classList.remove('loading');
    // Show success message
    showAlert('Security settings updated successfully!', 'success');
  }, 1500);
});

function showAlert(message, type) {
  const alert = document.createElement('div');
  alert.className = `alert alert-${type}`;
  alert.textContent = message;
  
  const header = document.querySelector('.settings-header');
  header.insertAdjacentElement('afterend', alert);
  
  setTimeout(() => {
    alert.remove();
  }, 3000);
}
</script>
{% endblock %}
