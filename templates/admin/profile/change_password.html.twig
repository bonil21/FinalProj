{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'profile' %}
{% block title %}GreenBites | Change Password{% endblock %}

{% block admin_content %}
<div class="header">
  <h1 class="page-title"><i class="bi bi-key"></i> Change Password</h1>
  <p style="color: #6b7280; margin-top: 0.5rem;">Update your account password</p>
</div>

{% if error %}
  <div style="background: #fee; border: 1px solid #ef5350; border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem; color: #b71c1c;">
    <i class="bi bi-exclamation-triangle"></i> {{ error }}
  </div>
{% endif %}

{% if success %}
  <div style="background: #e8f5e9; border: 1px solid #6BB97F; border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem; color: #2e7d32;">
    <i class="bi bi-check-circle"></i> Password changed successfully! 
    <strong>Please log out and log back in for the changes to take effect.</strong>
    <div style="margin-top: 0.5rem;">
      <a href="{{ path('app_logout') }}" style="background: #43b649; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-weight: 600; display: inline-block;">
        <i class="bi bi-box-arrow-right"></i> Logout Now
      </a>
    </div>
  </div>
{% endif %}

<div style="background: #F6E6D7; border: 1px solid #E4CFBF; border-radius: 16px; padding: 2rem; max-width: 600px;">
  <form method="post" style="display: grid; gap: 1.5rem;">
    <div>
      <label for="current_password" style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem;">Current Password</label>
      <input type="password" id="current_password" name="current_password" required 
             style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #E4CFBF; background: #fff; box-sizing: border-box;">
    </div>
    
    <div>
      <label for="new_password" style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem;">New Password</label>
      <input type="password" id="new_password" name="new_password" required minlength="6"
             style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #E4CFBF; background: #fff; box-sizing: border-box;">
      <small style="color: #6b7280; font-size: 0.85rem; margin-top: 0.25rem; display: block;">Must be at least 6 characters long</small>
    </div>
    
    <div>
      <label for="confirm_password" style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem;">Confirm New Password</label>
      <input type="password" id="confirm_password" name="confirm_password" required minlength="6"
             style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #E4CFBF; background: #fff; box-sizing: border-box;">
    </div>
    
    <div style="display: flex; gap: 1rem;">
      <button type="submit" style="background: #43b649; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; border: none; font-weight: 700; cursor: pointer;">
        <i class="bi bi-check-circle"></i> Change Password
      </button>
      <a href="{{ path('admin_profile') }}" style="background: #6b7280; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 700; display: inline-block;">
        <i class="bi bi-x-circle"></i> Cancel
      </a>
    </div>
  </form>
</div>
{% endblock %}

