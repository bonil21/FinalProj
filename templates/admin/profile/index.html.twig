{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'profile' %}
{% block title %}GreenBites | My Profile{% endblock %}

{% block admin_content %}
<div class="header mb-4">
  <h1 class="page-title"><i class="bi bi-person-circle"></i> My Profile</h1>
  <p class="text-muted">View your account details and manage account security.</p>
</div>

<div class="card">
  <div class="card-body">
    <table class="table">
      <tbody>
        <tr>
          <th>Email</th>
          <td>{{ user.email }}</td>
        </tr>
        <tr>
          <th>Name</th>
          <td>{{ user.name ?? 'N/A' }}</td>
        </tr>
        <tr>
          <th>Roles</th>
          <td>{{ user.roles|join(', ') }}</td>
        </tr>
        <tr>
          <th>Status</th>
          <td>{{ user.status|upper }}</td>
        </tr>
        <tr>
          <th>Created</th>
          <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : 'N/A' }}</td>
        </tr>
      </tbody>
    </table>

    <div class="mt-3">
      <a href="{{ path('admin_profile_change_password') }}" class="btn btn-primary">
        <i class="bi bi-key"></i> Change Password
      </a>
    </div>
  </div>
</div>
{% endblock %}
