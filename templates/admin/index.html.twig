{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'dashboard' %}
{% block title %}GreenBites | Admin Dashboard{% endblock %}

{% block admin_content %}
  <div class="dashboard-shell">
    <div class="mb-4">
      <h1 class="page-title"><span class="emoji">👋</span> Welcome Back, Admin</h1>
      <div class="admin-info dashboard-note">
        <span>Admin Panel - Last updated: {{ "now"|date("M d, Y H:i") }}</span>
      </div>
    </div>

    <div class="kpis mb-4">
      <div class="kpi"><div class="icon"><i class="bi bi-basket"></i></div><div class="meta"><span class="label">Total Products</span><span class="value">{{ totalProducts ?? 0 }}</span><span class="sub">Live items</span></div></div>
      <div class="kpi"><div class="icon"><i class="bi bi-people"></i></div><div class="meta"><span class="label">Total Users</span><span class="value">{{ totalUsers ?? 0 }}</span><span class="sub">All accounts</span></div></div>
      <div class="kpi"><div class="icon"><i class="bi bi-person"></i></div><div class="meta"><span class="label">Total Staff</span><span class="value">{{ totalStaff ?? 0 }}</span><span class="sub">Staff members</span></div></div>
      <div class="kpi"><div class="icon"><i class="bi bi-file-earmark-text"></i></div><div class="meta"><span class="label">Active Subscriptions</span><span class="value">{{ activeSubscriptions ?? 0 }}</span><span class="sub">Current billing cycle</span></div></div>
      <div class="kpi"><div class="icon"><i class="bi bi-box-seam"></i></div><div class="meta"><span class="label">Orders Today</span><span class="value">{{ ordersToday ?? 0 }}</span><span class="sub">Since midnight</span></div></div>
      <div class="kpi"><div class="icon">₱</div><div class="meta"><span class="label">Revenue</span><span class="value">₱{{ (todayRevenue ?? 0)|number_format(0, '.', ',') }}</span><span class="sub">Gross today</span></div></div>
    </div>

    <div class="dash-grid">
      <div class="panel">
        <h3>Next Order</h3>
        {% set now = date('now') %}
        {% set next = recentOrders|first %}
        <div class="next-order-card">
          <div class="muted">{{ next ? (next.createdAt ? next.createdAt|date('M d, Y') : 'Scheduled') : 'No orders yet' }}</div>
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="fw-bold">{{ next ? (next.customer ? next.customer.name : 'N/A') : '—' }}</div>
              <div class="muted">Order # {{ next ? next.orderNumber : '—' }}</div>
            </div>
            <span class="chip">₱{{ next ? (next.totalAmount|number_format(2)) : '0.00' }}</span>
          </div>
        </div>

        <div class="mini-list">
          {% for product in products|slice(0,3) %}
            <div class="mini-item">
              {% if product.image %}
                <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="{{ product.name }}">
              {% else %}
                <img alt="">
              {% endif %}
              <div>
                <div class="fw-bold">{{ product.name }}</div>
                <div class="muted">{{ product.category }}</div>
              </div>
              <div class="muted">₱{{ product.price }}</div>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="panel">
        <div class="calendar">
          {% set now = date('now') %}
          {% set first = (now|date('Y-m-01'))|date('Y-m-d') %}
          {% set daysInMonth = now|date('t') %}
          {% set startDow = (first|date('N')) %}
          <div class="month">
            <div class="h6 m-0">{{ now|date('F') }}</div>
            <div class="chip">{{ now|date('Y') }}</div>
          </div>
          <div class="grid">
            {% for d in ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'] %}
              <div class="dow">{{ d }}</div>
            {% endfor %}
            {% for i in 1..(startDow-1) %}<div></div>{% endfor %}
            {% for d in 1..daysInMonth %}
              {% set isToday = (now|date('j') == d) %}
              <div class="day {{ isToday ? 'today' : '' }}">{{ d }}</div>
            {% endfor %}
          </div>
        </div>

        <div class="panel mt-3 mb-0">
          <h3>Top 3 Meals</h3>
          <div class="mini-list">
            {% for product in products|slice(0,3) %}
              <div class="mini-item">
                {% if product.image %}
                  <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="{{ product.name }}">
                {% else %}
                  <img alt="">
                {% endif %}
                <div>
                  <div class="fw-bold">{{ product.name }}</div>
                  <div class="muted">{{ product.category }}</div>
                </div>
                <span class="chip">₱{{ product.price }}</span>
              </div>
            {% else %}
              <div class="muted">No meals available.</div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="panel">
        <h3>Last Orders</h3>
        <div class="last-orders">
          {% for order in recentOrders %}
            <div class="last-item">
              <div class="dot">{{ loop.index }}</div>
              <div>
                <div class="fw-bold">{{ order.customer ? order.customer.name : 'N/A' }}</div>
                <div class="muted">Order #{{ order.orderNumber }} • {{ order.createdAt ? order.createdAt|date('M d, Y') : '' }}</div>
              </div>
              <span class="chip">₱{{ order.totalAmount|number_format(0) }}</span>
            </div>
          {% else %}
            <div class="muted">No recent orders.</div>
          {% endfor %}
        </div>

        <h3 class="mt-4">Recent Activity</h3>
        <div class="last-orders">
          {% for log in recentLogs|slice(0, 5) %}
            {% set actionClass = {
              'CREATE': 'dot--create',
              'UPDATE': 'dot--update',
              'DELETE': 'dot--delete',
              'LOGIN': 'dot--login'
            } %}
            <div class="last-item">
              <div class="dot {{ actionClass[log.action] ?? 'dot--default' }}">{{ log.action|slice(0,1) }}</div>
              <div>
                <div class="fw-bold">{{ log.userEmail }}</div>
                <div class="muted">{{ log.action }} {{ log.entity ?? 'N/A' }} • {{ log.createdAt|date('M d, H:i') }}</div>
              </div>
            </div>
          {% else %}
            <div class="muted">No recent activity.</div>
          {% endfor %}
        </div>
        <div class="mt-3">
          <a href="{{ path('admin_logs_index') }}" class="btn-ghost d-block text-center">View All Logs →</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
