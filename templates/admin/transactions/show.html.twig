{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'payments' %}
{% block title %}Transaction #{{ transaction.id }} - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-arrow-left-right"></i> Transaction #{{ transaction.id }}</h2>
    <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Back to Transactions
    </a>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">{{ transaction.customer.name }} ({{ transaction.customer.email }})</dd>

            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">{{ transaction.type|title }}</dd>

            <dt class="col-sm-3">Amount</dt>
            <dd class="col-sm-9">${{ transaction.amount }} {{ transaction.currency|upper }}</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">{{ transaction.status|title }}</dd>

            <dt class="col-sm-3">Reference</dt>
            <dd class="col-sm-9">{{ transaction.reference ?: '—' }}</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">{{ transaction.description ?: '—' }}</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">{{ transaction.createdAt ? transaction.createdAt|date('M d, Y H:i') : '—' }}</dd>

            <dt class="col-sm-3">Processed At</dt>
            <dd class="col-sm-9">{{ transaction.processedAt ? transaction.processedAt|date('M d, Y H:i') : '—' }}</dd>

            <dt class="col-sm-3">Payment ID</dt>
            <dd class="col-sm-9">{{ transaction.payment ? transaction.payment.id : '—' }}</dd>

            <dt class="col-sm-3">Subscription ID</dt>
            <dd class="col-sm-9">{{ transaction.subscription ? transaction.subscription.id : '—' }}</dd>
        </dl>
    </div>
</div>
{% endblock %}
