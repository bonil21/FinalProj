{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'payments' %}
{% block title %}Transactions - Admin{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🔄 Transactions</h2>
    <a href="{{ path('app_subscription_index') }}" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> Back to Subscriptions
    </a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" class="form-control" name="q" value="{{ search }}" placeholder="Search customer, reference, type...">
    </div>
    <div class="col-md-3">
        <select class="form-select" name="status">
            <option value="">All statuses</option>
            {% for s in ['completed', 'pending', 'failed', 'cancelled'] %}
                <option value="{{ s }}" {% if statusFilter == s %}selected{% endif %}>{{ s|title }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" name="limit">
            {% for n in [10, 20, 50, 100] %}
                <option value="{{ n }}" {% if limit == n %}selected{% endif %}>{{ n }} / page</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" href="{{ path('app_transaction_index') }}">Reset</a>
    </div>
</form>

<div class="row mb-3">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="text-success">{{ statusCounts['completed'] ?? 0 }}</h4>
                <small class="text-muted">Completed</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="text-warning">{{ statusCounts['pending'] ?? 0 }}</h4>
                <small class="text-muted">Pending</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="text-danger">{{ statusCounts['failed'] ?? 0 }}</h4>
                <small class="text-muted">Failed</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="text-info">{{ totalTransactions }}</h4>
                <small class="text-muted">Total</small>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">All Transactions</h5>
    </div>
    <div class="card-body">
        {% if transactions is empty %}
            <div class="text-center py-5">
                <i class="fas fa-exchange-alt fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">No transactions found</h4>
                <p class="text-muted">Transactions will appear here when customers make purchases or subscriptions are processed.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Reference</th>
                            <th>Created</th>
                            <th>Processed</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for transaction in transactions %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2">
                                            {{ transaction.customer.name|first|upper }}
                                        </div>
                                        <div>
                                            <div class="fw-bold">{{ transaction.customer.name }}</div>
                                            <small class="text-muted">{{ transaction.customer.email }}</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    {% set typeClass = {
                                        'payment': 'success',
                                        'refund': 'warning',
                                        'subscription': 'info',
                                        'adjustment': 'secondary'
                                    } %}
                                    <span class="badge bg-{{ typeClass[transaction.type] ?? 'secondary' }}">
                                        {{ transaction.type|title }}
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold">${{ transaction.amount }}</div>
                                    <small class="text-muted">{{ transaction.currency|upper }}</small>
                                </td>
                                <td>
                                    {% set statusClass = {
                                        'completed': 'success',
                                        'pending': 'warning',
                                        'failed': 'danger',
                                        'cancelled': 'secondary'
                                    } %}
                                    <span class="badge bg-{{ statusClass[transaction.status] ?? 'secondary' }}">
                                        {{ transaction.status|title }}
                                    </span>
                                </td>
                                <td>
                                    {% if transaction.reference %}
                                        <code class="small">{{ transaction.reference }}</code>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div>{{ transaction.createdAt|date('M d, Y') }}</div>
                                    <small class="text-muted">{{ transaction.createdAt|date('H:i') }}</small>
                                </td>
                                <td>
                                    {% if transaction.processedAt %}
                                        <div>{{ transaction.processedAt|date('M d, Y') }}</div>
                                        <small class="text-muted">{{ transaction.processedAt|date('H:i') }}</small>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_transaction_show', {'id': transaction.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}

        {% if totalPages > 1 %}
            <div class="d-flex justify-content-between align-items-center mt-3">
                <small class="text-muted">Page {{ page }} of {{ totalPages }}</small>
                <div class="btn-group">
                    {% set prevPage = page - 1 %}
                    {% set nextPage = page + 1 %}
                    <a class="btn btn-outline-secondary btn-sm {% if page <= 1 %}disabled{% endif %}" href="{{ path('app_transaction_index', {page: prevPage, limit: limit, status: statusFilter, q: search}) }}">Prev</a>
                    <a class="btn btn-outline-secondary btn-sm {% if page >= totalPages %}disabled{% endif %}" href="{{ path('app_transaction_index', {page: nextPage, limit: limit, status: statusFilter, q: search}) }}">Next</a>
                </div>
            </div>
        {% endif %}
    </div>
</div>

<style>
.avatar-sm {
    width: 32px;
    height: 32px;
    font-size: 14px;
}
</style>
{% endblock %}
