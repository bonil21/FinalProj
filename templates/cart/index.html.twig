{% extends 'base.html.twig' %}

{% block title %}Shopping Cart - GreenBites{% endblock %}

{% block body %}
<div style="max-width: 1200px; margin: 0 auto; padding: 48px 24px;">
    <h1 style="font-size: 2.5rem; font-weight: 800; color: #2F5133; margin-bottom: 2rem;">Shopping Cart</h1>

    {% for message in app.flashes('success') %}
        <div style="background: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div style="background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
            {{ message }}
        </div>
    {% endfor %}

    {% if items|length > 0 %}
    <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 32px; margin-bottom: 32px;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 2px solid #E4CFBF;">
                    <th style="padding: 16px; text-align: left; color: #2F5133; font-weight: 700;">Item</th>
                    <th style="padding: 16px; text-align: center; color: #2F5133; font-weight: 700;">Quantity</th>
                    <th style="padding: 16px; text-align: right; color: #2F5133; font-weight: 700;">Price</th>
                    <th style="padding: 16px; text-align: right; color: #2F5133; font-weight: 700;">Total</th>
                    <th style="padding: 16px; text-align: center; color: #2F5133; font-weight: 700;">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr style="border-bottom: 1px solid #E4CFBF;">
                    <td style="padding: 16px;">
                        <div style="display: flex; align-items: center; gap: 16px;">
                            {% if item.image %}
                                <img src="/uploads/images/{{ item.image }}" alt="{{ item.name }}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;" />
                            {% else %}
                                <div style="width: 80px; height: 80px; background: #E7F0DC; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 2rem;">📦</div>
                            {% endif %}
                            <div>
                                <h3 style="font-size: 1.1rem; color: #2F5133; font-weight: 700; margin: 0 0 4px 0;">{{ item.name }}</h3>
                                <span style="color: #6b7280; font-size: 0.9rem;">{{ item.type|capitalize }}</span>
                            </div>
                        </div>
                    </td>
                    <td style="padding: 16px; text-align: center;">{{ item.quantity }}</td>
                    <td style="padding: 16px; text-align: right; color: #43b649; font-weight: 700;">₱{{ item.price|number_format(2, '.', ',') }}</td>
                    <td style="padding: 16px; text-align: right; color: #43b649; font-weight: 700;">₱{{ (item.price * item.quantity)|number_format(2, '.', ',') }}</td>
                    <td style="padding: 16px; text-align: center;">
                        <form method="post" action="{{ path('app_cart_remove', {type: item.type, id: item.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('cart_remove') }}">
                            <button type="submit" style="background: #dc3545; color: white; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: 600;">Remove</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 24px;">
        <div>
            <h2 style="font-size: 1.8rem; color: #2F5133; font-weight: 700; margin-bottom: 8px;">Total: ₱{{ total|number_format(2, '.', ',') }}</h2>
            <p style="color: #6b7280; margin: 0;">{{ items|length }} item(s) in cart</p>
        </div>
        <div style="display: flex; gap: 16px;">
            <form method="post" action="{{ path('app_cart_clear') }}" style="display: inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">
                <button type="submit" style="background: #6b7280; color: white; border: none; padding: 12px 24px; border-radius: 12px; cursor: pointer; font-weight: 600;">Clear Cart</button>
            </form>
            <a href="{{ path('app_products_index') }}" style="background: linear-gradient(120deg, #43b649 0%, #6BB97F 100%); color: white; padding: 12px 24px; border-radius: 12px; text-decoration: none; font-weight: 700;">Continue Shopping</a>
            {% if app.user %}
            <a href="{{ path('app_checkout') }}" style="background: linear-gradient(120deg, #43b649 0%, #ffc107 100%); color: white; padding: 12px 32px; border-radius: 12px; text-decoration: none; font-weight: 700; box-shadow: 0 4px 16px rgba(67, 182, 73, 0.3);">Place Order</a>
            {% else %}
            <a href="{{ path('app_checkout') }}" style="background: linear-gradient(120deg, #43b649 0%, #ffc107 100%); color: white; padding: 12px 32px; border-radius: 12px; text-decoration: none; font-weight: 700; box-shadow: 0 4px 16px rgba(67, 182, 73, 0.3);">Log in to checkout</a>
            {% endif %}
        </div>
    </div>
    {% else %}
    <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 80px 32px; text-align: center;">
        <div style="font-size: 4rem; margin-bottom: 24px;">🛒</div>
        <h2 style="font-size: 2rem; color: #2F5133; font-weight: 700; margin-bottom: 16px;">Your cart is empty</h2>
        <p style="color: #6b7280; margin-bottom: 32px;">Start adding items to your cart to see them here.</p>
        <a href="{{ path('app_products_index') }}" style="background: linear-gradient(120deg, #43b649 0%, #6BB97F 100%); color: white; padding: 16px 32px; border-radius: 12px; text-decoration: none; font-weight: 700; display: inline-block;">Browse Products</a>
    </div>
    {% endif %}
</div>
{% endblock %}

