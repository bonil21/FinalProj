{% extends 'base.html.twig' %}

{% block title %}Checkout - GreenBites{% endblock %}

{% block body %}
<div style="max-width: 1200px; margin: 0 auto; padding: 48px 24px;">
    <h1 style="font-size: 2.5rem; font-weight: 800; color: #2F5133; margin-bottom: 2rem;">Checkout</h1>

    {% for message in app.flashes('error') %}
        <div style="background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
            {{ message }}
        </div>
    {% endfor %}

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 32px;">
        <!-- Order Summary -->
        <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 32px;">
            <h2 style="font-size: 1.8rem; color: #2F5133; font-weight: 700; margin-bottom: 24px;">Order Summary</h2>
            
            <div style="margin-bottom: 24px;">
                {% for item in items %}
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px solid #E4CFBF;">
                    <div>
                        <h3 style="font-size: 1.1rem; color: #2F5133; font-weight: 700; margin: 0 0 4px 0;">{{ item.name }}</h3>
                        <span style="color: #6b7280; font-size: 0.9rem;">Quantity: {{ item.quantity }}</span>
                    </div>
                    <div style="text-align: right;">
                        <span style="color: #43b649; font-weight: 700; font-size: 1.1rem;">₱{{ (item.price * item.quantity)|number_format(2, '.', ',') }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>

            <div style="border-top: 2px solid #E4CFBF; padding-top: 16px; margin-top: 16px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                    <span style="color: #6b7280; font-size: 1rem;">Subtotal:</span>
                    <span style="color: #2F5133; font-weight: 600;">₱{{ total|number_format(2, '.', ',') }}</span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                    <span style="color: #6b7280; font-size: 1rem;">Delivery:</span>
                    <span style="color: #2F5133; font-weight: 600;">Free</span>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 16px; border-top: 2px solid #43b649; margin-top: 16px;">
                    <span style="color: #2F5133; font-weight: 700; font-size: 1.3rem;">Total:</span>
                    <span style="color: #43b649; font-weight: 900; font-size: 1.8rem;">₱{{ total|number_format(2, '.', ',') }}</span>
                </div>
            </div>
        </div>

        <!-- Delivery Information -->
        <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 32px;">
            <h2 style="font-size: 1.8rem; color: #2F5133; font-weight: 700; margin-bottom: 24px;">Delivery Information</h2>
            
            <form method="POST" action="{{ path('app_checkout_create_order') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('checkout_create_order') }}">
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 700; color: #2F5133; margin-bottom: 8px;">Delivery Address *</label>
                    <textarea 
                        name="delivery_address" 
                        required 
                        rows="4" 
                        placeholder="Enter your complete delivery address"
                        style="width: 100%; padding: 12px; border: 2px solid #E4CFBF; border-radius: 12px; font-size: 1rem; resize: vertical; box-sizing: border-box;"
                    >{{ customer.address ?? '' }}</textarea>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 700; color: #2F5133; margin-bottom: 8px;">Contact Information</label>
                    <div style="background: #F6E6D7; padding: 12px; border-radius: 8px; color: #2F5133;">
                        <div><strong>Name:</strong> {{ customer.name ?? 'N/A' }}</div>
                        <div><strong>Email:</strong> {{ customer.email ?? 'N/A' }}</div>
                        <div><strong>Phone:</strong> {{ customer.phone ?? 'N/A' }}</div>
                    </div>
                </div>

                <button type="submit" style="width: 100%; padding: 16px; background: linear-gradient(120deg, #43b649 0%, #6BB97F 100%); color: white; border: none; border-radius: 14px; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.2s ease; box-shadow: 0 4px 12px rgba(67,182,73,0.3);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(67,182,73,0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(67,182,73,0.3)';">Proceed to Payment</button>
            </form>

            <a href="{{ path('app_cart') }}" style="display: block; text-align: center; margin-top: 16px; color: #6b7280; text-decoration: none; font-weight: 600;">← Back to Cart</a>
        </div>
    </div>
</div>
{% endblock %}

