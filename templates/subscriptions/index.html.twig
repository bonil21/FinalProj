{% extends 'base.html.twig' %}

{% block title %}Subscriptions - GreenBites{% endblock %}

{% block body %}
<div class="container" style="padding: 40px 20px;">
  <h1 style="color:#2F5133; font-weight:900; margin-bottom: 12px;">Choose your subscription</h1>
  <p style="color:#5f6b74; margin-bottom: 24px;">Pick a plan that fits you and start enjoying fresh meals.</p>

  {% for message in app.flashes('success') %}
    <div style="padding:12px 16px; border-radius:10px; background:#e8f5e9; color:#2f5133; margin-bottom:16px;">
      {{ message }}
    </div>
  {% endfor %}
  {% for message in app.flashes('error') %}
    <div style="padding:12px 16px; border-radius:10px; background:#fdecea; color:#8a1f17; margin-bottom:16px;">
      {{ message }}
    </div>
  {% endfor %}

  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap:20px;">
    {% for plan in plans %}
      <div style="background: linear-gradient(135deg,#FFFFFF,#F6E6D7); border:1px solid #E4CFBF; border-radius:14px; padding:18px; box-shadow:0 8px 20px rgba(0,0,0,0.06); display:flex; flex-direction:column; gap:10px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <h3 style="margin:0; color:#2F5133;">{{ plan.name }}</h3>
          <span style="color:#FFA62B; font-weight:800;">₱{{ plan.price|number_format(2, '.', ',') }}</span>
        </div>
        <p style="color:#5f6b74; margin:0;">{{ plan.description }}</p>
        <div style="color:#2F5133; font-weight:700;">{{ plan.mealsIncluded }} meals • {{ plan.billingInterval|capitalize }}</div>
        <form action="{{ path('customer_subscribe', {id: plan.id}) }}" method="post">
          <input type="hidden" name="_token" value="{{ csrf_token('subscribe' ~ plan.id) }}">
          <button type="submit" style="width:100%; margin-top:8px; background: linear-gradient(135deg,#2F5133,#3B6B4A); color:#fff; border:0; padding:10px 14px; border-radius:10px; font-weight:700; cursor:pointer;">Subscribe</button>
        </form>
      </div>
    {% else %}
      <p>No subscription plans available yet.</p>
    {% endfor %}
  </div>
</div>
{% endblock %}

