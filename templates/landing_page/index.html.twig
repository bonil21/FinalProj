{% extends 'base.html.twig' %}

{% block title %}GreenBites - Fresh Organic Vegetables{% endblock %}

{% block body %}
<div class="homepage page-shell">
    <section class="gb-hero gb-hero--bg">
        <div class="container gb-hero__inner">
            <div class="gb-hero__copy">
                <p class="gb-hero__brand">
                    <span class="gb-hero__brand-mark">Greenbites</span>
                </p>
                <h1 class="gb-hero__title">
                    <span class="gb-hero__title-green">Freshness in every</span>
                    <span class="gb-hero__title-gold">bite</span>
                </h1>
                <p class="gb-hero__subtitle">Save up to 50% off on your first order</p>

                <div class="gb-hero__cta">
                    <a class="btn btn-primary" href="{{ path('app_products_index') }}">Shop now</a>
                    {% if not app.user %}
                        <a class="btn btn-ghost" href="{{ path('app_register') }}">Create account</a>
                    {% else %}
                        <a class="btn btn-ghost" href="{{ path('app_cart') }}">View cart</a>
                    {% endif %}
                </div>
            </div>

            <div class="gb-hero__visual" aria-hidden="true">
                <div class="gb-hero__image-card">
                    <img src="{{ asset('imageeee/bg.jpg') }}" alt="">
                </div>
            </div>
        </div>
    </section>

    <section class="gb-actions">
        <div class="container gb-actions__row">
            <a class="gb-action" href="#plans">Subscription plan</a>
            <a class="gb-action" href="{{ path('app_products_index') }}">Our healthy product</a>
            <a class="gb-action" href="#about">About the Green Bites</a>
            <a class="gb-action" href="#contact">Contact us</a>
        </div>
    </section>

    <section class="feature-band section section--padded">
        <div class="container">
            <div class="section-lead"><div class="section-pill"></div></div>
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-card__icon"><i class="bi bi-shield-check"></i></div>
                    <strong>Pesticide-Free</strong>
                    <span>100% organic cultivation</span>
                </div>
                <div class="feature-card feature-card--accent-red">
                    <div class="feature-card__icon"><i class="bi bi-truck"></i></div>
                    <strong>Farm Direct</strong>
                    <span>Delivered fresh daily</span>
                </div>
                <div class="feature-card feature-card--accent-gold">
                    <div class="feature-card__icon"><i class="bi bi-recycle"></i></div>
                    <strong>Sustainable</strong>
                    <span>Eco-friendly practices</span>
                </div>
                <div class="feature-card feature-card--accent-brown">
                    <div class="feature-card__icon"><i class="bi bi-people"></i></div>
                    <strong>Local Support</strong>
                    <span>Supporting local farmers</span>
                </div>
            </div>
        </div>
    </section>

    <section id="plans" class="plans-section section">
        <div class="container">
            <div class="section__header">
                <div>
                    <p class="eyebrow">Subscription plan</p>
                    <h2>Choose a plan that fits you</h2>
                    <p class="muted">Fresh, organic meals delivered to your door.</p>
                </div>
                <a class="btn btn-primary" href="{{ path('app_subscription_index') }}">View plans</a>
            </div>

            <div class="card-grid card-grid--plans">
                {% for plan in plans %}
                    {% set planSkin = ['plan-card--soft-green','plan-card--soft-gold','plan-card--soft-olive','plan-card--soft-brown'][loop.index0 % 4] %}
                    <article class="plan-card {{ planSkin }}">
                        <div>
                            <h3 style="margin:0;">{{ plan.name }}</h3>
                            <p class="plan-card__price">
                                ₱{{ plan.price|number_format(2, '.', ',') }}
                                <span>/ {{ plan.billingInterval|title }}</span>
                            </p>
                            <p class="plan-card__meta">
                                <span class="badge">Meals: {{ plan.mealsIncluded }}</span>
                                {% if plan.active %}<span class="badge badge--soft">Active</span>{% endif %}
                            </p>
                        </div>
                        <p class="muted" style="font-weight:600;">{{ plan.description }}</p>
                        <form method="POST" action="{{ path('customer_subscribe', {id: plan.id}) }}" style="margin:0;">
                            <input type="hidden" name="_token" value="{{ csrf_token('subscribe_' ~ plan.id) }}">
                            <button class="btn btn-primary" type="submit" style="width:100%;">Subscribe</button>
                        </form>
                    </article>
                {% else %}
                    <div class="empty-state">No subscription plans available yet.</div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="highlight-section section">
        <div class="container highlight-shell">
            <div class="highlight-copy">
                <p class="eyebrow">Our healthy product</p>
                <h2>100% organic vegetables always fresh</h2>
                <p>Our farm-fresh vegetables are hand-picked daily and delivered within hours of harvest.</p>
                <a class="btn btn-primary" href="{{ path('app_products_index') }}">View all products</a>

                {% if categories is defined and categories|length > 0 %}
                    <div style="margin-top:16px;">
                        <p class="muted" style="font-weight:700; margin-bottom:10px;">Categories</p>
                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            {% for category in categories|slice(0, 8) %}
                                <span class="badge">{{ category.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="highlight-products">
                {% for product in featuredProducts|default(products|slice(0, 6))|slice(0, 6) %}
                    <div class="mini-card">
                        {% if product.image %}
                            <img src="{{ asset('imageeee/' ~ product.image) }}" alt="{{ product.name }}">
                        {% else %}
                            <img src="{{ asset('imageeee/bg.jpg') }}" alt="">
                        {% endif %}
                        <h4>{{ product.name }}</h4>
                        <p class="price">₱{{ product.price|number_format(2, '.', ',') }}</p>
                        <div style="display:flex; gap:10px; margin-top:10px; justify-content:center;">
                            <form method="POST" action="{{ path('app_cart_add_product', {id: product.id}) }}" style="margin:0;">
                                <input type="hidden" name="_token" value="{{ csrf_token('add_product_' ~ product.id) }}">
                                <button class="btn btn-primary" type="submit" style="padding:10px 14px;">Order</button>
                            </form>
                            <a class="btn btn-ghost" href="{{ path('app_products_show', {id: product.id}) }}" style="padding:10px 14px;">View</a>
                        </div>
                    </div>
                {% else %}
                    <div class="empty-state">No products available yet.</div>
                {% endfor %}
            </div>
        </div>
        <div class="section-divider"></div>
    </section>

    <section id="about" class="gb-about section section--muted">
        <div class="container gb-about__grid">
            <div class="gb-about__copy">
                <p class="eyebrow">About</p>
                <h2>THE GREEN BITES</h2>
                <p class="lead">Fresh, healthy meals delivered to your door. Eat clean, feel great.</p>
                <p class="muted">GreenBites connects you with local farms and prepares nourishing meals and produce bundles with quality you can taste.</p>
            </div>
            <div class="gb-about__media">
                <img src="{{ asset('imageeee/bg.jpg') }}" alt="Green Bites">
            </div>
        </div>
    </section>

    <footer id="contact" class="footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <h4>Contact us</h4>
                    <p class="muted">Phone: 0912-345-6789</p>
                    <p class="muted">Email: <a href="mailto:support@greenbites.com">support@greenbites.com</a></p>
                </div>
                <div>
                    <h4>Our socials</h4>
                    <ul>
                        <li><a href="#" rel="nofollow">Facebook</a></li>
                        <li><a href="#" rel="nofollow">Instagram</a></li>
                        <li><a href="#" rel="nofollow">Email</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Explore</h4>
                    <ul>
                        <li><a href="{{ path('app_landing_page') }}">Home</a></li>
                        <li><a href="{{ path('app_products_index') }}">Products</a></li>
                        <li><a href="{{ path('app_subscription_index') }}">Subscription plans</a></li>
                        {% if app.user %}
                            <li><a href="{{ path('app_cart') }}">Cart</a></li>
                        {% else %}
                            <li><a href="{{ path('app_login') }}">Login</a></li>
                        {% endif %}
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <div>© {{ "now"|date("Y") }} GreenBites</div>
                <ul class="footer-links">
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>
        </div>
    </footer>
</div>

{% endblock %}
