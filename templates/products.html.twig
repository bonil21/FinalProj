{% extends 'base.html.twig' %}

{% block title %}All Products - GreenBites{% endblock %}

{% block body %}
<div class="products-page container">
    <header class="products-list-header">
        <h1 class="products-list-title">All products</h1>
        {% if search_query is defined and search_query %}
            <p class="products-subtitle">Results for <strong>{{ search_query }}</strong> — <a class="text-link" href="{{ path('app_products_index') }}">Clear</a></p>
        {% else %}
            <p class="products-subtitle">Farm-fresh meals and produce, ready to order.</p>
        {% endif %}
    </header>

    <div class="products-grid">
        {% for product in products %}
            <article class="product-card">
                <a href="{{ path('app_products_show', {id: product.id}) }}" class="product-media">
                    {% if product.image %}
                        <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="{{ product.name }}" loading="lazy" width="400" height="400">
                    {% else %}
                        <span class="product-placeholder" aria-hidden="true">🥬</span>
                    {% endif %}
                </a>
                <div class="product-info">
                    {% if product.category %}
                        <span class="product-category">{{ product.category.name }}</span>
                    {% endif %}
                    <h2 class="product-name">
                        <a href="{{ path('app_products_show', {id: product.id}) }}">{{ product.name }}</a>
                    </h2>
                    <p class="product-description">{% set desc = product.description|default('') %}{{ desc|length > 120 ? desc|slice(0, 117) ~ '…' : desc }}</p>
                    <div class="product-price-row">
                        <span class="product-price">₱{{ product.price|number_format(2, '.', ',') }}</span>
                    </div>
                    <form method="POST" action="{{ path('app_cart_add_product', {id: product.id}) }}" class="product-cart-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('add_product_' ~ product.id) }}">
                        <button type="submit" class="btn-add">Add to cart</button>
                    </form>
                </div>
            </article>
        {% else %}
            <p class="empty-state" style="grid-column: 1 / -1;">No products found.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
