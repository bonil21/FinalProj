<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}GreenBites - Fresh Organic Produce{% endblock %}</title>
        <meta name="description" content="GreenBites - Fresh, healthy, 100% organic produce delivered to your door.">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🥬</text></svg>">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar">
            <div class="navbar-inner container">
                <a href="/" class="logo">
                    <img src="/imageeee/logo.png" alt="" />
                    GreenBites
                </a>
                <form class="search-box" method="get" action="/search">
                    <input type="text" name="q" placeholder="Search for products..." required />
                    <button type="submit">Search</button>
                </form>
                <div class="actions-wrap">
                    <div class="actions">
                        <a href="/cart" class="nav-link">Cart</a>
                        {% if app.user %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <span class="nav-link">Admin</span>
                                <a href="{{ path('admin_dashboard') }}" class="nav-link" style="background: #43b649; color: white; padding: 8px 16px; border-radius: 20px; font-weight: 600;"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            {% elseif is_granted('ROLE_STAFF') %}
                                <span class="nav-link">Staff</span>
                                <a href="{{ path('staff_dashboard') }}" class="nav-link" style="background: #43b649; color: white; padding: 8px 16px; border-radius: 20px; font-weight: 600;"><i class="bi bi-speedometer2"></i> Dashboard</a>
                            {% endif %}
                            <span class="nav-link">{{ app.user.email }}</span>
                            <a href="/logout" class="nav-link">Logout</a>
                        {% else %}
                            <a href="/login" class="nav-link">Login</a>
                            <a href="/register" class="nav-link">Register</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>
        {% block body %}{% endblock %}
        <script>
            // Toggle navbar visibility based on dashboard-container presence
            // Works with Turbo Drive by using turbo:load and turbo:render events
            (function() {
                // Prevent duplicate execution
                if (window.navbarInitialized) return;
                window.navbarInitialized = true;
                
                function toggleNavbar() {
                    const dashboardContainer = document.querySelector('.dashboard-container');
                    const navbar = document.querySelector('.navbar');
                    const body = document.body;
                    
                    if (!navbar) return;
                    
                    // Always remove inline styles first to prevent conflicts
                    navbar.style.removeProperty('display');
                    navbar.style.removeProperty('visibility');
                    navbar.style.removeProperty('opacity');
                    navbar.style.removeProperty('height');
                    navbar.style.removeProperty('padding');
                    navbar.style.removeProperty('margin');
                    navbar.style.removeProperty('overflow');
                    
                    if (dashboardContainer) {
                        // Hide navbar on dashboard pages - use multiple methods for reliability
                        body.classList.add('dashboard-page');
                        navbar.classList.add('hidden');
                        // Force hide with inline style as backup
                        navbar.style.setProperty('display', 'none', 'important');
                        navbar.style.setProperty('visibility', 'hidden', 'important');
                    } else {
                        // Show navbar on regular pages
                        body.classList.remove('dashboard-page');
                        navbar.classList.remove('hidden');
                        // Ensure it's visible
                        navbar.style.removeProperty('display');
                        navbar.style.removeProperty('visibility');
                    }
                }
                
                // Initialize navbar visibility - runs on every page load/navigation
                function initNavbar() {
                    toggleNavbar();
                }
                
                // Turbo events - these fire on every Turbo navigation
                // turbo:load fires after Turbo loads a new page
                document.addEventListener('turbo:load', initNavbar);
                // turbo:render fires after Turbo renders the page
                document.addEventListener('turbo:render', initNavbar);
                // turbo:before-cache fires before Turbo caches the page (cleanup)
                document.addEventListener('turbo:before-cache', function() {
                    // Clean up classes before page is cached
                    const navbar = document.querySelector('.navbar');
                    const body = document.body;
                    if (navbar) {
                        navbar.classList.remove('hidden');
                        navbar.style.removeProperty('display');
                        navbar.style.removeProperty('visibility');
                    }
                    if (body) {
                        body.classList.remove('dashboard-page');
                    }
                });
                
                // Fallback for initial page load (when Turbo hasn't loaded yet)
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initNavbar);
                } else {
                    initNavbar();
                }
                
                // Fallback for full page load (non-Turbo navigation)
                window.addEventListener('load', initNavbar);
            })();
        </script>
    </body>
</html>

