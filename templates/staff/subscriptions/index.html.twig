{% extends 'staff/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}GreenBites | Subscriptions Management{% endblock %}

{% block staff_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="page-title"><i class="bi bi-file-earmark-text"></i> Subscriptions</h1>
  <a href="{{ path('staff_subscription_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New Subscription</a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}

<div class="row mb-3">
    <div class="col-md-4">
        <div class="card text-center p-3 bg-light">
            <h3 class="text-success m-0">{{ statusCounts['active']|default(0) }}</h3>
            <p class="m-0 fw-semibold">Active</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3 bg-light">
            <h3 class="text-warning m-0">{{ statusCounts['trialing']|default(0) }}</h3>
            <p class="m-0 fw-semibold">Trialing</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3 bg-light">
            <h3 class="text-danger m-0">{{ statusCounts['cancelled']|default(0) }}</h3>
            <p class="m-0 fw-semibold">Cancelled</p>
        </div>
    </div>
</div>

<div class="mb-3">
    <a href="{{ path('staff_subscription_plan_index') }}" class="btn btn-outline-primary"><i class="bi bi-gear"></i> Manage Plans</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Customer, email, plan, subscription ID">
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All statuses</option>
                    {% for st in ['active', 'trialing', 'past_due', 'inactive', 'cancelled'] %}
                        <option value="{{ st }}" {% if statusFilter == st %}selected{% endif %}>{{ st|title }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Per page</label>
                <select name="limit" class="form-select">
                    {% for opt in [10, 20, 50, 100] %}
                        <option value="{{ opt }}" {% if limit == opt %}selected{% endif %}>{{ opt }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
                <a href="{{ path('staff_subscription_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Plan</th>
                        <th>Status</th>
                        <th>Start Date</th>
                        <th>Current Period</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for subscription in subscriptions %}
                    <tr>
                        <td class="fw-semibold">#{{ subscription.id }}</td>
                        <td>
                            {% if subscription.customer %}
                                <div class="fw-semibold">{{ subscription.customer.name }}</div>
                                <small class="text-muted">{{ subscription.customer.email }}</small>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if subscription.plan %}
                                <div class="fw-semibold">{{ subscription.plan.name }}</div>
                                <small class="text-muted">{{ subscription.plan.mealsIncluded }} meals</small>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td>
                            {% set statusClass = {
                                'active': 'bg-success',
                                'inactive': 'bg-secondary',
                                'cancelled': 'bg-danger',
                                'past_due': 'bg-warning',
                                'trialing': 'bg-info'
                            } %}
                            <span class="badge {{ statusClass[subscription.status] ?? 'bg-secondary' }}">
                                {{ subscription.status|title }}
                            </span>
                        </td>
                        <td>{{ subscription.startDate ? subscription.startDate|date('M d, Y') : '-' }}</td>
                        <td>
                            {% if subscription.currentPeriodStart and subscription.currentPeriodEnd %}
                                <small>{{ subscription.currentPeriodStart|date('M d') }} - {{ subscription.currentPeriodEnd|date('M d, Y') }}</small>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="text-nowrap">
                            <a href="{{ path('staff_subscription_show', {id: subscription.id}) }}" class="btn btn-outline-info btn-sm">View</a>
                            {% if subscription.createdBy == app.user %}
                                <a href="{{ path('staff_subscription_edit', {id: subscription.id}) }}" class="btn btn-outline-warning btn-sm">Edit</a>
                                <form method="post" action="{{ path('staff_subscription_delete', {id: subscription.id}) }}" class="d-inline" onsubmit="return confirm('Delete this subscription?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subscription.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No subscriptions found.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if totalPages > 1 %}
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Page {{ page }} of {{ totalPages }} ({{ totalSubscriptions }} total)</small>
        <div class="btn-group">
            <a class="btn btn-outline-secondary {% if page <= 1 %}disabled{% endif %}"
               href="{{ page <= 1 ? '#' : path('staff_subscription_index', {page: page - 1, limit: limit, status: statusFilter, q: search}) }}">
                Previous
            </a>
            <a class="btn btn-outline-secondary {% if page >= totalPages %}disabled{% endif %}"
               href="{{ page >= totalPages ? '#' : path('staff_subscription_index', {page: page + 1, limit: limit, status: statusFilter, q: search}) }}">
                Next
            </a>
        </div>
    </div>
{% endif %}
{% endblock %}
