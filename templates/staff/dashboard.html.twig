{% extends 'staff/_base.html.twig' %}
{% set active_menu = 'dashboard' %}
{% block title %}GreenBites | Staff Dashboard{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    .dashboard-tables { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.2rem; }
    @media (max-width: 992px) { .dashboard-tables { grid-template-columns: 1fr; } }
    .table-section { background: #F6E6D7; border: 1px solid #E4CFBF; border-radius: 16px; box-shadow: 0 8px 26px rgba(0,0,0,0.06); padding: 1.1rem; }
    .table-section h2 { margin: 0 0 .9rem 0; color: #2F5133; font-size: 1.1rem; font-weight: 800; letter-spacing: .02em; }
    table { width: 100%; border-collapse: collapse; }
    thead th { font-size: .8rem; font-weight: 700; color: #2F5133; text-transform: uppercase; letter-spacing: .06em; background: #ECD5C4; }
    tbody td, thead th { padding: .9rem 1rem; border-bottom: 1px solid #E4CFBF; }
    tbody td { color: #1f2937; }
    .table-section a { color: #3B6B4A; text-decoration: none; }
    .table-section a:hover { text-decoration: underline; }
    tbody tr:hover { background: #FAF0E8; }
    .panel { background: linear-gradient(135deg, #FFFFFF, #F9F9F9); border: 1px solid #E4CFBF; border-radius: 18px; box-shadow: 0 12px 32px rgba(0,0,0,0.08); padding: 1.5rem; margin-bottom: 1.5rem; }
    .panel h3 { margin: 0 0 .75rem 0; color: #2F5133; font-weight: 900; font-size: 1.3rem; }
    .kpi { background: linear-gradient(135deg, #E7F0DC, #D4E4C4); border: 1px solid #C4D4B4; border-radius: 16px; padding: 1.5rem; display: flex; align-items: center; gap: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.08); }
    .kpi .icon { font-size: 2.5rem; }
    .kpi .meta { flex: 1; }
    .kpi .label { display: block; color: #2F5133; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem; }
    .kpi .value { display: block; color: #1a3d1f; font-size: 2rem; font-weight: 900; }
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .text-center { text-align: center; }
    .muted { color: #6b7280; font-size: .9rem; }
  </style>
{% endblock %}

{% block staff_content %}
<div style="padding: 2rem;">
  <h1 style="color: #2F5133; font-size: 2rem; font-weight: 900; margin-bottom: 2rem;">Staff Dashboard</h1>
  
  <div class="kpi-grid">
    <div class="kpi">
      <div class="icon"><i class="bi bi-basket" style="font-size: 2rem;"></i></div>
      <div class="meta">
        <span class="label">My Products</span>
        <span class="value">{{ totalProducts }}</span>
      </div>
    </div>
    <div class="kpi">
      <div class="icon">📦</div>
      <div class="meta">
        <span class="label">My Orders</span>
        <span class="value">{{ totalOrders }}</span>
      </div>
    </div>
  </div>

  <div class="dashboard-tables">
    <div class="table-section">
      <h2>My Products</h2>
      {% if myProducts|length > 0 %}
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Price</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for product in myProducts|slice(0, 10) %}
              <tr>
                <td>{{ product.name }}</td>
                <td>${{ product.price|number_format(2) }}</td>
                <td>
                  <a href="{{ path('app_products_show', {id: product.id}) }}">View</a> |
                  <a href="{{ path('app_products_edit', {id: product.id}) }}">Edit</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        {% if myProducts|length > 10 %}
          <p class="muted" style="margin-top: 1rem;">Showing 10 of {{ myProducts|length }} products. <a href="{{ path('app_products_index') }}">View all</a></p>
        {% endif %}
      {% else %}
        <p class="muted text-center" style="padding: 2rem;">No products yet. <a href="{{ path('app_products_new') }}">Create your first product</a></p>
      {% endif %}
    </div>

    <div class="table-section">
      <h2>My Orders</h2>
      {% if myOrders|length > 0 %}
        <table>
          <thead>
            <tr>
              <th>Order #</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {% for order in myOrders|slice(0, 10) %}
              <tr>
                <td>{{ order.orderNumber }}</td>
                <td>${{ order.totalAmount|number_format(2) }}</td>
                <td>{{ order.status }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="muted text-center" style="padding: 2rem;">No orders yet.</p>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}

