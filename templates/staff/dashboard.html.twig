{% extends 'staff/_base.html.twig' %}
{% set active_menu = 'dashboard' %}
{% block title %}GreenBites | Staff Dashboard{% endblock %}

{% block staff_content %}
<div class="dashboard-shell">
  <h1 class="dashboard-title">Staff Dashboard</h1>

  <div class="kpi-grid">
    <div class="kpi">
      <div class="icon"><i class="bi bi-basket"></i></div>
      <div class="meta">
        <span class="label">My Products</span>
        <span class="value">{{ totalProducts }}</span>
      </div>
    </div>
    <div class="kpi">
      <div class="icon"><i class="bi bi-box-seam"></i></div>
      <div class="meta">
        <span class="label">My Orders</span>
        <span class="value">{{ totalOrders }}</span>
      </div>
    </div>
  </div>

  <div class="dashboard-tables">
    <div class="table-section">
      <h2>My Products</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for product in myProducts|slice(0, 10) %}
            <tr>
              <td>{{ product.name }}</td>
              <td>₱{{ product.price|number_format(2) }}</td>
              <td>
                <a href="{{ path('app_products_show', {id: product.id}) }}">View</a> |
                <a href="{{ path('app_products_edit', {id: product.id}) }}">Edit</a>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3" class="text-center">No products yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="table-section">
      <h2>My Orders</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Order #</th>
            <th>Amount</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {% for order in myOrders|slice(0, 10) %}
            <tr>
              <td>{{ order.orderNumber }}</td>
              <td>₱{{ order.totalAmount|number_format(2) }}</td>
              <td>{{ order.status|upper }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3" class="text-center">No orders yet.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
