{% extends 'base.html.twig' %}

{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('admin') }}
{% endblock %}

{% block body %}
<div class="dashboard-container">
  <div class="sidebar">
    <div>
      <img src="{{ asset('imageeee/logo.png') }}" alt="GreenBites Logo 2025" style="width:80px; margin-bottom:1.5rem;">
      <h2>GreenBites</h2>
      <a href="{{ path('app_landing_page') }}" class="{% if active_menu is defined and active_menu == 'home' %}active{% endif %}"><i class="bi bi-house-door"></i> Home</a>
      <a href="{{ path('staff_dashboard') }}" class="{% if active_menu is defined and active_menu == 'dashboard' %}active{% endif %}"><i class="bi bi-speedometer2"></i> Dashboard</a>
      <a href="{{ path('app_products_index') }}" class="{% if active_menu is defined and active_menu == 'products' %}active{% endif %}" style="font-weight: bold; font-size: 1.1em;"><i class="bi bi-basket"></i> Products</a>
      <a href="{{ path('app_products_new') }}" class="{% if active_menu is defined and active_menu == 'products_new' %}active{% endif %}" style="font-weight: bold; font-size: 1.1em;"><i class="bi bi-plus-circle"></i> Create Product</a>
      <hr>
      <a href="{{ path('staff_subscription_index') }}" class="{% if active_menu is defined and active_menu == 'subscriptions' %}active{% endif %}" style="font-weight: bold; font-size: 1.1em;"><i class="bi bi-file-earmark-text"></i> Subscriptions</a>
      <hr>
      <a href="{{ path('staff_profile') }}" class="{% if active_menu is defined and active_menu == 'profile' %}active{% endif %}" style="font-weight: bold; font-size: 1.1em;"><i class="bi bi-person-circle"></i> My Profile</a>
      <hr>
      <a href="{{ path('app_logout') }}" style="text-align:center; margin-top:1rem; color: #E7F0DC;"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </div>

  <div class="main-content">
    {% for message in app.flashes('error') %}
        <div style="background: #fee; border: 2px solid #fcc; color: #c33; padding: 1rem; margin: 1rem; border-radius: 8px; font-weight: 600;">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div style="background: #efe; border: 2px solid #cfc; color: #3c3; padding: 1rem; margin: 1rem; border-radius: 8px; font-weight: 600;">
            {{ message }}
        </div>
    {% endfor %}
    {% block staff_content %}{% endblock %}
  </div>
</div>
{% endblock %}

