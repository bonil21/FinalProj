{% extends 'staff/_base.html.twig' %}
{% set active_menu = 'profile' %}
{% block title %}My Profile - GreenBites{% endblock %}

{% block staff_content %}
<div style="padding: 2rem;">
  <div style="margin-bottom: 1.5rem;">
    <h1 class="page-title" style="color: #2F5133; font-size: 2rem; font-weight: 900; margin-bottom: 0.5rem;">
      <i class="bi bi-person-circle"></i> My Profile
    </h1>
    <p style="color: #6b7280; margin-top: 0.5rem;">View and manage your staff account information</p>
  </div>

  <div style="background: #F6E6D7; border: 1px solid #E4CFBF; border-radius: 16px; padding: 2rem; margin-bottom: 1.5rem;">
    <div style="display: grid; gap: 1.5rem;">
      <div>
        <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Email Address</label>
        <div style="background: #fff; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #E4CFBF; color: #1f2937;">{{ user.email }}</div>
      </div>
      
      <div>
        <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Name</label>
        <div style="background: #fff; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #E4CFBF; color: #1f2937;">{{ user.name ?? 'Not set' }}</div>
      </div>
      
      <div>
        <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Role</label>
        <div style="background: #E7F0DC; padding: 0.5rem 1rem; border-radius: 8px; display: inline-block;">
          <span style="color: #2F5133; font-weight: 700;">{{ user.roles|join(', ') }}</span>
        </div>
      </div>
      
      <div>
        <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Account Status</label>
        <div style="background: {% if user.status == 'active' %}#6BB97F{% else %}#ef5350{% endif %}; padding: 0.5rem 1rem; border-radius: 8px; display: inline-block;">
          <span style="color: white; font-weight: 700; text-transform: uppercase;">{{ user.status }}</span>
        </div>
      </div>
      
      <div>
        <label style="display: block; color: #2F5133; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Account Created</label>
        <div style="background: #fff; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid #E4CFBF; color: #1f2937;">{{ user.createdAt ? user.createdAt|date('F d, Y H:i:s') : 'N/A' }}</div>
      </div>
    </div>
  </div>

  <div style="display: flex; gap: 1rem;">
    <a href="{{ path('staff_profile_change_password') }}" style="background: #43b649; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 700; display: inline-block;">
      <i class="bi bi-key"></i> Change Password
    </a>
    <a href="{{ path('staff_dashboard') }}" style="background: #6b7280; color: white; padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 700; display: inline-block;">
      <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
  </div>
</div>
{% endblock %}

