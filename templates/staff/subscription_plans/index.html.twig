{% extends 'staff/_base.html.twig' %}
{% set active_menu = 'subscriptions' %}
{% block title %}GreenBites | Subscription Plans{% endblock %}

{% block staff_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="page-title"><i class="bi bi-gear"></i> Subscription Plans</h1>
  <a href="{{ path('staff_subscription_plan_new') }}" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New Plan</a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}

<div class="row mb-3">
    <div class="col-md-4">
        <div class="card text-center p-3 bg-light">
            <h3 class="text-success m-0">{{ totalPlans }}</h3>
            <p class="m-0 fw-semibold">Total Plans</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3 bg-light">
            <h3 class="text-primary m-0">{{ activeCounts.active|default(0) }}</h3>
            <p class="m-0 fw-semibold">Active</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-3 bg-light">
            <h3 class="text-secondary m-0">{{ activeCounts.inactive|default(0) }}</h3>
            <p class="m-0 fw-semibold">Inactive</p>
        </div>
    </div>
</div>

<div class="mb-3">
    <a href="{{ path('staff_subscription_index') }}" class="btn btn-outline-primary"><i class="bi bi-file-earmark-text"></i> View Subscriptions</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Search</label>
                <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Name, code, description">
            </div>
            <div class="col-md-3">
                <label class="form-label">Active State</label>
                <select name="active" class="form-select">
                    <option value="">All plans</option>
                    <option value="1" {% if activeFilter == '1' %}selected{% endif %}>Active</option>
                    <option value="0" {% if activeFilter == '0' %}selected{% endif %}>Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Per page</label>
                <select name="limit" class="form-select">
                    {% for opt in [6, 12, 24, 48] %}
                        <option value="{{ opt }}" {% if limit == opt %}selected{% endif %}>{{ opt }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
                <a href="{{ path('staff_subscription_plan_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="row">
    {% for plan in plans %}
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 {% if not plan.active %}opacity-75{% endif %}">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h3 class="h5 m-0">{{ plan.name }}</h3>
                    <span class="badge bg-{{ plan.active ? 'success' : 'secondary' }}">{{ plan.active ? 'Active' : 'Inactive' }}</span>
                </div>

                <div class="mb-2"><code class="small">{{ plan.code }}</code></div>
                <p class="text-muted">{{ plan.description }}</p>

                <div class="row text-center mb-3">
                    <div class="col-6">
                        <div class="fw-bold text-success">${{ plan.price }}</div>
                        <small class="text-muted">{{ plan.billingInterval }}</small>
                    </div>
                    <div class="col-6">
                        <div class="fw-bold">{{ plan.mealsIncluded }}</div>
                        <small class="text-muted">meals</small>
                    </div>
                </div>

                {% if plan.createdBy == app.user %}
                    <div class="d-flex gap-2">
                        <a href="{{ path('staff_subscription_plan_edit', {id: plan.id}) }}" class="btn btn-outline-primary btn-sm w-100">Edit</a>
                        <form method="post" action="{{ path('staff_subscription_plan_delete', {id: plan.id}) }}" class="w-100" onsubmit="return confirm('Delete this plan?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ plan.id) }}">
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">Delete</button>
                        </form>
                    </div>
                {% else %}
                    <small class="text-muted">Created by {{ plan.createdBy ? plan.createdBy.email : 'Admin' }}</small>
                {% endif %}
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12">
        <div class="card p-5 text-center">
            <h3 class="h5 text-muted mb-3">No subscription plans found</h3>
            <a href="{{ path('staff_subscription_plan_new') }}" class="btn btn-primary">Create Plan</a>
        </div>
    </div>
    {% endfor %}
</div>

{% if totalPages > 1 %}
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Page {{ page }} of {{ totalPages }}</small>
        <div class="btn-group">
            <a class="btn btn-outline-secondary {% if page <= 1 %}disabled{% endif %}"
               href="{{ page <= 1 ? '#' : path('staff_subscription_plan_index', {page: page - 1, limit: limit, active: activeFilter, q: search}) }}">
                Previous
            </a>
            <a class="btn btn-outline-secondary {% if page >= totalPages %}disabled{% endif %}"
               href="{{ page >= totalPages ? '#' : path('staff_subscription_plan_index', {page: page + 1, limit: limit, active: activeFilter, q: search}) }}">
                Next
            </a>
        </div>
    </div>
{% endif %}
{% endblock %}
