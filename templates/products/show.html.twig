{% extends 'admin/_base.html.twig' %}
{% set active_menu = 'products' %}

{% block title %}Product Details - GreenBites{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap');
        /* Avoid overriding admin layout body styles */

        .container {
            max-width: 700px;
            margin: 40px auto;
            background: #fff;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0px 6px 18px rgba(0, 0, 0, 0.1);
        }

        /* Logo */
        .logo {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 10px;
        }

        .logo img {
            width: 55px;
            margin-right: 8px;
        }

        .logo-text {
            font-size: 2rem;
            font-weight: 700;
        }

        .logo-text span:first-child {
            color: #2e7d32;
        }
        .logo-text span:last-child {
            color: #f9a825;
        }

        h2 {
            text-align: center;
            font-size: 1.4rem;
            margin: 25px 0 35px;
            font-weight: 700;
            color: #111;
        }

        /* Product details table */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        th, td {
            padding: 14px 16px;
            border-bottom: 1px solid #eee;
            text-align: left;
        }

        th {
            width: 200px;
            font-weight: 600;
            color: #2e7d32;
        }

        td {
            color: #333;
        }

        /* Buttons */
        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn {
            display: inline-block;
            padding: 10px 18px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            transition: 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn-back {
            background: #f9a825;
            color: #fff;
        }
        .btn-back:hover {
            background: #f57f17;
        }

        .btn-edit {
            background: #2e7d32;
            color: #fff;
        }
        .btn-edit:hover {
            background: #1b5e20;
        }

        .btn-delete {
            background: #e53935;
            color: #fff;
        }
        .btn-delete:hover {
            background: #b71c1c;
        }
    </style>
{% endblock %}

{% block admin_content %}
    <div class="container">
        <!-- Logo -->
        <div class="logo">
            <img src="{{ asset('imageeee/logo.png') }}" alt="GreenBites Logo">
            <div class="logo-text">
                <span>Green</span><span>Bites</span>
            </div>
        </div>

        <h2>PRODUCT DETAILS</h2>

        {% if product.image %}
            <div style="text-align:center; margin-bottom:20px;">
                <img src="{{  asset('uploads/images/' ~ product.image) }}" alt="Product Image" style="max-width:300px; max-height:300px; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
            </div>
        {% endif %}
        <table>
            <tbody>
                <tr>
                    <th>ID</th>
                    <td>{{ product.id }}</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>{{ product.name }}</td>
                </tr>
                <tr>
                    <th>Category</th>
                    <td>{{ product.category }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ product.description }}</td>
                </tr>
                <tr>
                    <th>Price</th>
                    <td>{{ product.price }}</td>
                </tr>
                <tr>
                    <th>Nutritional Info</th>
                    <td>{{ product.NutritionalInfo }}</td>
                </tr>
                <tr>
                    <th>Availability</th>
                    <td>{{ product.Availability }}</td>
                </tr>
                <tr>
                    <th>Subscription Eligible</th>
                    <td>{{ product.SubscriptionEligible }}</td>
                </tr>
            </tbody>
        </table>

        <div class="actions">
            <a href="{{ path('admin_products') }}" class="btn btn-back" data-turbo="false">← Back</a>
            <a href="{{ path('app_products_edit', {'id': product.id}) }}" class="btn btn-edit" data-turbo="false">Edit</a>
            {{ include('products/_delete_form.html.twig', { 'attr': {'class': 'btn-delete'} }) }}
        </div>
    </div>
{% endblock %}
