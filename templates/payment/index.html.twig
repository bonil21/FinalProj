{% extends 'base.html.twig' %}

{% block title %}Payment - GreenBites{% endblock %}

{% block body %}
<div style="max-width: 800px; margin: 0 auto; padding: 48px 24px;">
    <h1 style="font-size: 2.5rem; font-weight: 800; color: #2F5133; margin-bottom: 2rem;">Complete Payment</h1>

    {% for message in app.flashes('error') %}
        <div style="background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
            {{ message }}
        </div>
    {% endfor %}

    <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 32px; margin-bottom: 24px;">
        {% if type == 'order' %}
            <h2 style="font-size: 1.5rem; color: #2F5133; font-weight: 700; margin-bottom: 16px;">Order Details</h2>
            <div style="background: #F6E6D7; padding: 20px; border-radius: 12px; margin-bottom: 24px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="color: #6b7280;"><strong>Order Number:</strong></span>
                    <span style="color: #2F5133; font-weight: 700;">{{ order.orderNumber }}</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="color: #6b7280;"><strong>Total Amount:</strong></span>
                    <span style="color: #43b649; font-weight: 900; font-size: 1.5rem;">₱{{ order.totalAmount|number_format(2, '.', ',') }}</span>
                </div>
                {% if order.deliveryAddress %}
                <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #E4CFBF;">
                    <span style="color: #6b7280;"><strong>Delivery Address:</strong></span>
                    <div style="color: #2F5133; margin-top: 4px;">{{ order.deliveryAddress }}</div>
                </div>
                {% endif %}
            </div>
        {% else %}
            <h2 style="font-size: 1.5rem; color: #2F5133; font-weight: 700; margin-bottom: 16px;">Subscription Details</h2>
            <div style="background: #F6E6D7; padding: 20px; border-radius: 12px; margin-bottom: 24px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="color: #6b7280;"><strong>Plan:</strong></span>
                    <span style="color: #2F5133; font-weight: 700;">{{ subscription.plan.name }}</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="color: #6b7280;"><strong>Billing Period:</strong></span>
                    <span style="color: #2F5133; font-weight: 700;">{{ subscription.plan.billingInterval|capitalize }}</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: #6b7280;"><strong>Amount:</strong></span>
                    <span style="color: #43b649; font-weight: 900; font-size: 1.5rem;">₱{{ amount|number_format(2, '.', ',') }}</span>
                </div>
            </div>
        {% endif %}
    </div>

    <div style="background: #FFFFFF; border-radius: 20px; box-shadow: 0 8px 32px rgba(47,81,51,0.12); padding: 32px;">
        <h2 style="font-size: 1.8rem; color: #2F5133; font-weight: 700; margin-bottom: 24px;">Select Payment Method</h2>
        
        <form method="POST" action="{{ path('app_payment_process') }}">
            {% if type == 'order' %}
                <input type="hidden" name="order_id" value="{{ order.id }}">
            {% else %}
                <input type="hidden" name="subscription_id" value="{{ subscription.id }}">
            {% endif %}

            <div style="display: grid; gap: 16px; margin-bottom: 24px;">
                <!-- Cash Option -->
                <label style="display: flex; align-items: center; padding: 20px; border: 2px solid #E4CFBF; border-radius: 12px; cursor: pointer; transition: all 0.2s ease; background: #FFFFFF;" onmouseover="this.style.borderColor='#43b649'; this.style.background='#E7F0DC';" onmouseout="this.style.borderColor='#E4CFBF'; this.style.background='#FFFFFF';">
                    <input type="radio" name="payment_method" value="cash" required style="margin-right: 16px; width: 20px; height: 20px; cursor: pointer;">
                    <div style="flex: 1;">
                        <div style="font-size: 1.2rem; font-weight: 700; color: #2F5133; margin-bottom: 4px;">💵 Cash on Delivery</div>
                        <div style="color: #6b7280; font-size: 0.9rem;">Pay with cash when your order arrives</div>
                    </div>
                </label>

                <!-- GCash Option -->
                <label style="display: flex; align-items: center; padding: 20px; border: 2px solid #E4CFBF; border-radius: 12px; cursor: pointer; transition: all 0.2s ease; background: #FFFFFF;" onmouseover="this.style.borderColor='#43b649'; this.style.background='#E7F0DC';" onmouseout="this.style.borderColor='#E4CFBF'; this.style.background='#FFFFFF';">
                    <input type="radio" name="payment_method" value="gcash" required style="margin-right: 16px; width: 20px; height: 20px; cursor: pointer;">
                    <div style="flex: 1;">
                        <div style="font-size: 1.2rem; font-weight: 700; color: #2F5133; margin-bottom: 4px;">📱 GCash</div>
                        <div style="color: #6b7280; font-size: 0.9rem;">Pay via GCash mobile wallet</div>
                    </div>
                </label>

                <!-- ATM/Bank Transfer Option -->
                <label style="display: flex; align-items: center; padding: 20px; border: 2px solid #E4CFBF; border-radius: 12px; cursor: pointer; transition: all 0.2s ease; background: #FFFFFF;" onmouseover="this.style.borderColor='#43b649'; this.style.background='#E7F0DC';" onmouseout="this.style.borderColor='#E4CFBF'; this.style.background='#FFFFFF';">
                    <input type="radio" name="payment_method" value="atm" required style="margin-right: 16px; width: 20px; height: 20px; cursor: pointer;">
                    <div style="flex: 1;">
                        <div style="font-size: 1.2rem; font-weight: 700; color: #2F5133; margin-bottom: 4px;">🏦 ATM / Bank Transfer</div>
                        <div style="color: #6b7280; font-size: 0.9rem;">Pay via bank transfer or ATM deposit</div>
                    </div>
                </label>
            </div>

            <button type="submit" style="width: 100%; padding: 16px; background: linear-gradient(120deg, #43b649 0%, #6BB97F 100%); color: white; border: none; border-radius: 14px; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: all 0.2s ease; box-shadow: 0 4px 12px rgba(67,182,73,0.3);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(67,182,73,0.4)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(67,182,73,0.3)';">Complete Payment</button>
        </form>
    </div>
</div>
{% endblock %}

